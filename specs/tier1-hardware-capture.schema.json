{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.example/specs/tier1-hardware-capture.schema.json",
  "title": "PooleOS Private Tier-1 Hardware Capture",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "collected_at_utc", "collection_mode", "collector", "mutation_guard", "privacy_guard", "host_context", "security", "system", "processor", "memory", "storage", "display", "network", "pnp_devices", "monitor", "firmware_tables", "sensors_power", "collector_errors"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_tier1_hardware_private_capture"},
    "collected_at_utc": {"type": "string"},
    "collection_mode": {"const": "read_only"},
    "collector": {"type": "object", "required": ["version", "script_sha256"]},
    "mutation_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firmware_write", "disk_write", "tpm_write", "boot_configuration_write", "device_configuration_write", "power_action", "stress_load"],
      "properties": {
        "firmware_write": {"const": false},
        "disk_write": {"const": false},
        "tpm_write": {"const": false},
        "boot_configuration_write": {"const": false},
        "device_configuration_write": {"const": false},
        "power_action": {"const": false},
        "stress_load": {"const": false}
      }
    },
    "privacy_guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["serial_numbers_collected", "mac_addresses_collected", "uuids_collected", "full_pnp_instance_paths_collected", "user_or_host_names_collected", "tpm_ek_or_certificate_material_collected", "raw_firmware_table_bytes_retained"],
      "properties": {
        "serial_numbers_collected": {"const": false},
        "mac_addresses_collected": {"const": false},
        "uuids_collected": {"const": false},
        "full_pnp_instance_paths_collected": {"const": false},
        "user_or_host_names_collected": {"const": false},
        "tpm_ek_or_certificate_material_collected": {"const": false},
        "raw_firmware_table_bytes_retained": {"const": false}
      }
    },
    "host_context": {"type": "object", "required": ["architecture", "firmware_type", "hypervisor_present"]},
    "security": {"type": "object", "required": ["secure_boot", "tpm"]},
    "system": {"type": "object", "required": ["baseboard", "bios", "computer_system"]},
    "processor": {"type": "array", "minItems": 1},
    "memory": {"type": "array", "minItems": 2},
    "storage": {"type": "array", "minItems": 2},
    "display": {"type": "array", "minItems": 1},
    "network": {"type": "array", "minItems": 1},
    "pnp_devices": {"type": "array", "minItems": 1},
    "monitor": {"type": "object", "required": ["status", "records", "serial_field_collected"]},
    "firmware_tables": {"type": "object", "required": ["acpi", "smbios"]},
    "sensors_power": {"type": "object", "required": ["status", "temperature_probe_count", "battery_count", "ups_count", "active_probe_performed"]},
    "collector_errors": {"type": "array"}
  }
}
