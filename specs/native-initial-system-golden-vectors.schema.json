{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-initial-system-golden-vectors.schema.json",
  "title": "PooleOS PINIT1 golden vectors",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "status",
    "production_ready",
    "vectors",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_initial_system_golden_vectors"},
    "contract_id": {"const": "PINIT1"},
    "status": {"const": "synthetic_non_promoting_golden_bytes"},
    "production_ready": {"const": false},
    "vectors": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "purpose", "byte_count", "sha256", "summary", "component_count", "service_count", "hex"],
        "properties": {
          "id": {"type": "string"},
          "purpose": {"type": "string"},
          "byte_count": {"type": "integer", "minimum": 1},
          "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
          "summary": {"type": "string", "pattern": "^OK;"},
          "component_count": {"type": "integer", "minimum": 1},
          "service_count": {"type": "integer", "minimum": 1},
          "hex": {"type": "string", "pattern": "^[0-9A-F]+$"}
        }
      }
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {"type": "string"}
    }
  }
}
