      "properties": {
        "magic_hex": {"const": "504250310D0A1A0A"}, "major": {"const": 1}, "minor": {"const": 0}, "endianness": {"const": "little"}, "header_bytes": {"const": 64}, "descriptor_bytes": {"const": 32}, "alignment_bytes": {"const": 8}, "maximum_total_bytes": {"const": 1048576}, "maximum_record_count": {"const": 32}, "message_checksum": {"type": "string"}, "record_checksum": {"type": "string"}
      }
    },
