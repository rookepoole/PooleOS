{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/qemu-captured-boot-readiness.schema.json",
  "title": "PooleOS QEMU Captured Boot Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "promotion_language_allowed",
    "sources",
    "requirements",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.qemu_captured_boot_readiness"
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked",
        "ready_for_promotion",
        "invalid"
      ]
    },
    "promotion_language_allowed": {
      "type": "boolean"
    },
    "sources": {
      "type": "object",
      "required": [
        "rootfs_extraction_receipt",
        "qemu_captured_boot_receipt",
        "qemu_captured_boot_evidence"
      ],
      "properties": {
        "rootfs_extraction_receipt": {
          "$ref": "#/$defs/source"
        },
        "qemu_captured_boot_receipt": {
          "$ref": "#/$defs/source"
        },
        "qemu_captured_boot_evidence": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "failed_check_count",
        "unmet_requirement_count",
        "rootfs_receipt_status",
        "qemu_captured_boot_receipt_status",
        "captured_evidence_exists",
        "captured_evidence_valid",
        "promotion_language_allowed"
      ],
      "properties": {
        "failed_check_count": {
          "type": "integer"
        },
        "unmet_requirement_count": {
          "type": "integer"
        },
        "rootfs_receipt_status": {
          "type": "string"
        },
        "qemu_captured_boot_receipt_status": {
          "type": "string"
        },
        "captured_evidence_exists": {
          "type": "boolean"
        },
        "captured_evidence_valid": {
          "type": "boolean"
        },
        "promotion_language_allowed": {
          "type": "boolean"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "artifact_kind",
        "status"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "requirement": {
      "type": "object",
      "required": [
        "name",
        "met",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "met": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "check": {
      "type": "object",
      "required": [
        "name",
        "ok",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
