{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-recovery-contract.schema.json",
  "title": "PooleOS PREC1 recovery policy contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "status",
    "production_ready",
    "encoding",
    "policy_tables",
    "slot_policy",
    "state_policy",
    "failure_policy",
    "authority_policy",
    "activation_preconditions",
    "research_basis",
    "production_claims",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_recovery_contract"},
    "contract_id": {"const": "PREC1"},
    "status": {"const": "candidate_pre_abi_non_promoting"},
    "production_ready": {"const": false},
    "encoding": {"type": "object"},
    "policy_tables": {"type": "object"},
    "slot_policy": {"type": "object"},
    "state_policy": {"type": "object"},
    "failure_policy": {"type": "object"},
    "authority_policy": {"type": "object"},
    "activation_preconditions": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {"type": "string"}
    },
    "research_basis": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {"type": "string", "format": "uri"}
    },
    "production_claims": {"type": "object"},
    "claim_boundary": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {"type": "string"}
    }
  }
}
