{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/buildroot-configure.schema.json",
  "title": "PooleOS Buildroot Configure Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "buildroot_path",
    "external_path",
    "defconfig_name",
    "output_dir",
    "command",
    "exit_code",
    "stdout_tail",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.buildroot_configure"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "blocked"
      ]
    },
    "buildroot_path": {
      "type": "string"
    },
    "external_path": {
      "type": "string"
    },
    "defconfig_name": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exit_code": {
      "type": "integer"
    },
    "stdout_tail": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    }
  }
}
