{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/qemu-captured-boot-receipt.schema.json",
  "title": "PooleOS QEMU Captured Boot Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "fixture_boot_evidence",
    "captured_boot_evidence",
    "operator_receipt",
    "boot_evidence_ingested",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.qemu_captured_boot_receipt"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending_capture",
        "captured",
        "invalid"
      ]
    },
    "fixture_boot_evidence": {
      "$ref": "#/$defs/evidence_slot"
    },
    "captured_boot_evidence": {
      "$ref": "#/$defs/evidence_slot"
    },
    "operator_receipt": {
      "type": "object",
      "required": [
        "operator_executed",
        "codex_execution_performed",
        "expected_launcher_mode"
      ],
      "properties": {
        "operator_executed": {
          "type": "boolean"
        },
        "codex_execution_performed": {
          "type": "boolean"
        },
        "expected_launcher_mode": {
          "type": "string"
        }
      }
    },
    "boot_evidence_ingested": {
      "type": "boolean"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "failed_check_count",
        "captured_evidence_exists",
        "captured_boot_evidence_valid",
        "fixture_preserved",
        "boot_evidence_ingested"
      ],
      "properties": {
        "failed_check_count": {
          "type": "integer"
        },
        "captured_evidence_exists": {
          "type": "boolean"
        },
        "captured_boot_evidence_valid": {
          "type": "boolean"
        },
        "fixture_preserved": {
          "type": "boolean"
        },
        "boot_evidence_ingested": {
          "type": "boolean"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "evidence_slot": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "artifact_kind",
        "status",
        "evidence_source",
        "boot_evidence_claimed"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "evidence_source": {
          "type": "string"
        },
        "boot_evidence_claimed": {
          "type": "boolean"
        }
      }
    }
  }
}
