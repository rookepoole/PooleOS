{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pdc-golden-metamorphic-receipt.schema.json",
  "title": "PooleOS PDC Golden Metamorphic Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "corpus_version", "created_utc", "status", "bindings", "environment", "results", "negative_checks", "digests", "summary", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "0.2"},
    "artifact_kind": {"const": "pdc_golden_metamorphic_receipt"},
    "corpus_version": {"const": "PDC-GOLDEN-0.2"},
    "created_utc": {"type": "string", "minLength": 20},
    "status": {"const": "pass"},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verifier_implementation_path", "verifier_implementation_sha256", "corpus_path", "corpus_sha256", "math_contract_path", "math_contract_sha256", "predecessor_golden_path", "predecessor_golden_sha256", "representation_contract_path", "representation_contract_sha256", "representation_receipt_path", "representation_receipt_sha256"],
      "properties": {
        "verifier_implementation_path": {"const": "runtime/pdc_golden_metamorphic.py"},
        "verifier_implementation_sha256": {"$ref": "#/$defs/sha256"},
        "corpus_path": {"const": "runs/pdc_golden_metamorphic_corpus.json"},
        "corpus_sha256": {"$ref": "#/$defs/sha256"},
        "math_contract_path": {"const": "runs/pdc_math_contract.json"},
        "math_contract_sha256": {"$ref": "#/$defs/sha256"},
        "predecessor_golden_path": {"const": "runs/pdc_golden_vectors.json"},
        "predecessor_golden_sha256": {"$ref": "#/$defs/sha256"},
        "representation_contract_path": {"const": "runs/pdc_representation_contract.json"},
        "representation_contract_sha256": {"$ref": "#/$defs/sha256"},
        "representation_receipt_path": {"const": "runs/pdc_representation_receipt.json"},
        "representation_receipt_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python_version", "python_implementation", "platform", "executable"],
      "properties": {
        "python_version": {"type": "string", "minLength": 3},
        "python_implementation": {"type": "string", "minLength": 3},
        "platform": {"type": "string", "minLength": 5},
        "executable": {"type": "string", "minLength": 3}
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["threshold", "adversarial", "metamorphic", "non_relations"],
      "properties": {
        "threshold": {"$ref": "#/$defs/threshold_result"},
        "adversarial": {"$ref": "#/$defs/adversarial_result"},
        "metamorphic": {"$ref": "#/$defs/metamorphic_result"},
        "non_relations": {"$ref": "#/$defs/non_relation_result"}
      }
    },
    "negative_checks": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"$ref": "#/$defs/negative_check"}},
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corpus_record_set_sha256", "receipt_result_set_sha256", "negative_check_set_sha256"],
      "properties": {
        "corpus_record_set_sha256": {"$ref": "#/$defs/sha256"},
        "receipt_result_set_sha256": {"$ref": "#/$defs/sha256"},
        "negative_check_set_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["threshold_pair_count", "adversarial_case_count", "translation_relation_count", "axis_permutation_relation_count", "metamorphic_relation_count", "non_relation_count", "oracle_field_evaluation_count", "representation_round_trip_count", "negative_check_count", "failed_negative_check_count", "mismatch_count"],
      "properties": {
        "threshold_pair_count": {"const": 54},
        "adversarial_case_count": {"const": 8},
        "translation_relation_count": {"const": 32},
        "axis_permutation_relation_count": {"const": 40},
        "metamorphic_relation_count": {"const": 72},
        "non_relation_count": {"const": 6},
        "oracle_field_evaluation_count": {"const": 206},
        "representation_round_trip_count": {"const": 824},
        "negative_check_count": {"const": 10},
        "failed_negative_check_count": {"const": 0},
        "mismatch_count": {"const": 0}
      }
    },
    "claim_boundary": {"$ref": "#/$defs/nonempty_strings"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "nonempty_strings": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 12}},
    "threshold_result": {
      "type": "object", "additionalProperties": false,
      "required": ["case_count", "passed_count", "scalar_matrix_direct_agreement_count", "representation_round_trip_count", "mismatch_count", "result_set_sha256"],
      "properties": {"case_count": {"const": 54}, "passed_count": {"const": 54}, "scalar_matrix_direct_agreement_count": {"const": 54}, "representation_round_trip_count": {"const": 216}, "mismatch_count": {"const": 0}, "result_set_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "adversarial_result": {
      "type": "object", "additionalProperties": false,
      "required": ["case_count", "passed_count", "wraparound_probe_count", "representation_round_trip_count", "mismatch_count", "result_set_sha256"],
      "properties": {"case_count": {"const": 8}, "passed_count": {"const": 8}, "wraparound_probe_count": {"const": 4}, "representation_round_trip_count": {"const": 32}, "mismatch_count": {"const": 0}, "result_set_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "metamorphic_result": {
      "type": "object", "additionalProperties": false,
      "required": ["relation_count", "translation_relation_count", "axis_permutation_relation_count", "passed_count", "representation_round_trip_count", "mismatch_count", "result_set_sha256"],
      "properties": {"relation_count": {"const": 72}, "translation_relation_count": {"const": 32}, "axis_permutation_relation_count": {"const": 40}, "passed_count": {"const": 72}, "representation_round_trip_count": {"const": 576}, "mismatch_count": {"const": 0}, "result_set_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "non_relation_result": {
      "type": "object", "additionalProperties": false,
      "required": ["record_count", "passed_count", "finite_counterexample_count", "contract_exclusion_count", "mismatch_count", "result_set_sha256"],
      "properties": {"record_count": {"const": 6}, "passed_count": {"const": 6}, "finite_counterexample_count": {"const": 2}, "contract_exclusion_count": {"const": 4}, "mismatch_count": {"const": 0}, "result_set_sha256": {"$ref": "#/$defs/sha256"}}
    },
    "negative_check": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "passed", "error_type"],
      "properties": {"id": {"type": "string", "minLength": 8}, "passed": {"const": true}, "error_type": {"type": "string", "minLength": 5}}
    }
  }
}
