{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pooleos-native-checklist-coverage.schema.json",
  "title": "PooleOS native master-checklist coverage ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "source",
    "counting_rule",
    "coverage_policy",
    "unmapped_source_lines",
    "phase_coverage",
    "section_coverage",
    "added_requirements"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_checklist_coverage"},
    "status_date": {"type": "string", "format": "date"},
    "status": {"const": "pass"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_count", "line_count", "top_level_section_count", "checkbox_line_count", "declared_generated_implementation_item_count", "metadata_checkbox_count", "governing_preamble_checkbox_count", "section_checkbox_count"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
        "byte_count": {"const": 416063},
        "line_count": {"const": 10512},
        "top_level_section_count": {"const": 171},
        "checkbox_line_count": {"const": 8998},
        "declared_generated_implementation_item_count": {"const": 8996},
        "metadata_checkbox_count": {"const": 2},
        "governing_preamble_checkbox_count": {"const": 10},
        "section_checkbox_count": {"const": 8986}
      }
    },
    "counting_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "equation"],
      "properties": {"description": {"type": "string"}, "equation": {"type": "string"}}
    },
    "coverage_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["every_source_line_mapped", "every_section_mapped_once", "every_checkbox_inherited", "mapping_does_not_imply_completion", "source_text_is_immutable", "research_additions_are_separate"],
      "properties": {
        "every_source_line_mapped": {"const": true},
        "every_section_mapped_once": {"const": true},
        "every_checkbox_inherited": {"const": true},
        "mapping_does_not_imply_completion": {"const": true},
        "source_text_is_immutable": {"const": true},
        "research_additions_are_separate": {"const": true}
      }
    },
    "unmapped_source_lines": {"type": "array", "maxItems": 0},
    "phase_coverage": {
      "type": "array",
      "minItems": 40,
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["phase_id", "title", "status", "source_section_ids", "source_line_count", "source_checkbox_count", "added_requirement_ids"],
        "properties": {
          "phase_id": {"type": "string", "pattern": "^N([0-9]|[1-3][0-9])$"},
          "title": {"type": "string", "minLength": 1},
          "status": {"enum": ["complete", "partial", "blocked", "not_started"]},
          "source_section_ids": {"type": "array", "items": {"type": "string", "pattern": "^[0-9]{3}$"}, "uniqueItems": true},
          "source_line_count": {"type": "integer", "minimum": 0},
          "source_checkbox_count": {"type": "integer", "minimum": 0},
          "added_requirement_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "section_coverage": {
      "type": "array",
      "minItems": 171,
      "maxItems": 171,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "title", "start_line", "end_line", "line_count", "subheading_count", "checkbox_count", "phase_id", "phase_status", "completion_inferred"],
        "properties": {
          "section_id": {"type": "string", "pattern": "^[0-9]{3}$"},
          "title": {"type": "string", "minLength": 1},
          "start_line": {"type": "integer", "minimum": 17},
          "end_line": {"type": "integer", "maximum": 10512},
          "line_count": {"type": "integer", "minimum": 1},
          "subheading_count": {"type": "integer", "minimum": 0},
          "checkbox_count": {"type": "integer", "minimum": 1},
          "phase_id": {"type": "string", "pattern": "^N([0-9]|[1-3][0-9])$"},
          "phase_status": {"enum": ["complete", "partial", "blocked", "not_started"]},
          "completion_inferred": {"const": false}
        }
      }
    },
    "added_requirements": {
      "type": "array",
      "minItems": 42,
      "maxItems": 42,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "phase_id", "requirement", "basis"],
        "properties": {
          "id": {"type": "string", "pattern": "^ADD-[A-Z]+-[0-9]{3}$"},
          "phase_id": {"type": "string", "pattern": "^N([0-9]|[1-3][0-9])$"},
          "requirement": {"type": "string", "minLength": 20},
          "basis": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    }
  }
}
