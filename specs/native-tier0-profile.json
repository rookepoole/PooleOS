{
  "schema_version": "1.0",
  "artifact_kind": "pooleos_native_tier0_profile",
  "status_date": "2026-07-16",
  "profile_set_id": "POOLEOS-TIER0-Q35-1",
  "status": "frozen_for_non_promoting_qualification",
  "production_ready": false,
  "production_promotion_allowed": false,
  "phase_mapping": [
    "N4.1",
    "N4.2",
    "N4.3",
    "N4.4",
    "ADD-VIRTIO-001"
  ],
  "machine": {
    "type": "pc-q35-11.0",
    "architecture": "x86_64",
    "accelerator": "tcg",
    "tcg_thread_mode": "single",
    "cpu_model": "qemu64",
    "vcpus": 1,
    "sockets": 1,
    "dies": 1,
    "clusters": 1,
    "cores": 1,
    "threads": 1,
    "memory_mib": 512,
    "usb_enabled": false,
    "vmport_enabled": false,
    "guest_core_dump_control_available": false,
    "guest_core_dump_disabled": false,
    "network_enabled": false,
    "default_devices_enabled": false,
    "host_acceleration_enabled": false
  },
  "determinism": {
    "virtual_clock": "vm",
    "rtc_base": "utc",
    "rtc_driftfix": "none",
    "icount_shift": 0,
    "icount_align": false,
    "icount_sleep": false,
    "s3_enabled": false,
    "s4_enabled": false,
    "boot_menu_enabled": false,
    "strict_boot": true,
    "input_media_read_only": true,
    "fresh_vars_copy_per_launch": true,
    "command_generation_must_be_byte_identical": true,
    "guest_execution_determinism_claimed": false
  },
  "devices": {
    "required": [
      "virtio-blk-pci-non-transitional",
      "isa-debug-exit",
      "isa-debugcon",
      "16550a-serial"
    ],
    "virtio_transport": "pci-modern-only",
    "virtio_legacy_allowed": false,
    "virtio_transitional_allowed": false,
    "prohibited": [
      "virtio-9p",
      "host-directory-sharing",
      "user-networking",
      "tap-networking",
      "bridge-networking",
      "usb-redirection",
      "passthrough",
      "vfio",
      "vhost"
    ]
  },
  "firmware_flash": {
    "code_unit": 0,
    "code_format": "raw",
    "code_read_only": true,
    "vars_unit": 1,
    "vars_format": "raw",
    "vars_template_never_written": true,
    "vars_working_copy_scope": "one_launch_directory"
  },
  "profiles": [
    {
      "id": "bootstrap-debug",
      "firmware_role": "debug_code_read_only",
      "smm": false,
      "secure_flash": false,
      "secure_boot_enabled": false,
      "secure_boot_claimed": false
    },
    {
      "id": "secure-firmware-prep",
      "firmware_role": "secure_code_read_only",
      "smm": true,
      "secure_flash": true,
      "secure_boot_enabled": false,
      "secure_boot_claimed": false
    }
  ],
  "base_argument_template": [
    "-L",
    "$QEMU_SHARE",
    "-nodefaults",
    "-no-user-config",
    "-machine",
    "$MACHINE",
    "-accel",
    "tcg,thread=single",
    "-cpu",
    "qemu64",
    "-smp",
    "1,sockets=1,dies=1,clusters=1,cores=1,threads=1,maxcpus=1",
    "-m",
    "512M",
    "-rtc",
    "base=utc,clock=vm,driftfix=none",
    "-icount",
    "shift=0,align=off,sleep=off",
    "-global",
    "ICH9-LPC.disable_s3=1",
    "-global",
    "ICH9-LPC.disable_s4=1",
    "-drive",
    "if=pflash,format=raw,unit=0,readonly=on,file=$OVMF_CODE",
    "-drive",
    "if=pflash,format=raw,unit=1,file=$OVMF_VARS",
    "-drive",
    "if=none,id=pooleos_media,format=raw,readonly=on,file=$MEDIA",
    "-device",
    "virtio-blk-pci-non-transitional,drive=pooleos_media",
    "-chardev",
    "file,id=poole_serial,path=$SERIAL_LOG,append=off",
    "-serial",
    "chardev:poole_serial",
    "-debugcon",
    "file:$DEBUGCON_LOG",
    "-global",
    "isa-debugcon.iobase=0x402",
    "-device",
    "isa-debug-exit,iobase=0xf4,iosize=0x04",
    "-display",
    "none",
    "-monitor",
    "none",
    "-nic",
    "none",
    "-no-reboot",
    "-boot",
    "strict=on,menu=off",
    "-d",
    "guest_errors,unimp",
    "-D",
    "$TRACE_LOG"
  ],
  "profile_overlays": {
    "bootstrap-debug": [],
    "secure-firmware-prep": [
      "-global",
      "driver=cfi.pflash01,property=secure,value=on"
    ]
  },
  "debug_overlay": [
    "-S",
    "-gdb",
    "tcp:127.0.0.1:1234,server=on,wait=off"
  ],
  "evidence_contract": {
    "serial_log": "pooleos.serial.log",
    "debugcon_log": "pooleos.debugcon.log",
    "qemu_trace_log": "qemu.trace.log",
    "vars_copy": "OVMF_VARS.fd",
    "launch_receipt": "native_tier0_launch_receipt.json",
    "serial_is_primary_boot_evidence": true,
    "debug_exit_port": "0xF4",
    "debug_exit_size_bytes": 4,
    "debug_exit_host_status_formula": "(guest_value << 1) | 1",
    "guest_exit_values_assigned": false,
    "gdb_bind_address": "127.0.0.1",
    "gdb_port": 1234,
    "gdb_enabled_by_default": false,
    "boot_timeout_seconds": 30,
    "qualification_start_timeout_seconds": 30
  },
  "launch_policy": {
    "entrypoint": "tools/run_native_tier0.py",
    "dry_run_default": true,
    "execute_requires_explicit_flag": true,
    "media_must_exist": true,
    "media_must_be_regular_file": true,
    "media_writable_by_qemu": false,
    "buildroot_or_linux_guest_allowed": false,
    "absolute_paths_allowed_in_public_receipt": false,
    "unknown_arguments_allowed": false,
    "run_directory_must_not_be_repository_tracked": true
  },
  "required_negative_controls": [
    "NEG-N4-ANDROID-QEMU",
    "NEG-N4-DEVELOPMENT-QEMU",
    "NEG-N4-QEMU-HASH",
    "NEG-N4-QEMU-VERSION",
    "NEG-N4-MACHINE",
    "NEG-N4-FIRMWARE-CODE-HASH",
    "NEG-N4-FIRMWARE-CODE-WRITABLE",
    "NEG-N4-VARS-TEMPLATE-REUSE",
    "NEG-N4-LEGACY-VIRTIO",
    "NEG-N4-TRANSITIONAL-VIRTIO",
    "NEG-N4-NETWORK",
    "NEG-N4-HOST-SHARE",
    "NEG-N4-HOST-ACCEL",
    "NEG-N4-EXTRA-ARG",
    "NEG-N4-BUILDROOT-GUEST",
    "NEG-N4-LINUX-GUEST",
    "NEG-N4-PATH-ESCAPE",
    "NEG-N4-BOOT-OVERCLAIM"
  ],
  "claim_boundary": [
    "A passing Tier 0 qualification proves only exact host-tool, firmware-byte, capability-probe, machine-instantiation, and command-generation controls.",
    "A paused QMP handshake is not a PooleBoot boot, PooleKernel execution, VIRTIO driver proof, or guest determinism proof.",
    "The secure firmware profile does not claim enrolled keys, Secure Boot enforcement, measured boot, or owner signatures.",
    "QEMU and OVMF are development inputs and are not PooleOS production components.",
    "No Buildroot or Linux guest artifact can satisfy a native PooleOS gate.",
    "The Windows candidate cannot disable guest memory dumps through the q35 dump-guest-core property and is not production-qualified."
  ]
}
