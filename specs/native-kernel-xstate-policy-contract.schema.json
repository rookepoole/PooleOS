{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PooleOS PKXSTATE1 contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "selected_move_id",
    "status_date",
    "status",
    "production_ready",
    "production_promotion_allowed",
    "phase_mapping",
    "development_profile",
    "policy",
    "authority_gate",
    "qualification",
    "source_register",
    "required_negative_controls",
    "claims",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_xstate_policy_contract"},
    "contract_id": {"const": "PKXSTATE1"},
    "selected_move_id": {"const": "N7-XSTATE-POLICY-001"},
    "status_date": {"type": "string", "format": "date"},
    "status": {"type": "string", "minLength": 1},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "phase_mapping": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
    "development_profile": {"type": "object"},
    "policy": {"type": "object"},
    "authority_gate": {"type": "object"},
    "qualification": {"type": "object"},
    "source_register": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "required_negative_controls": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "claims": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "non_claims": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
  }
}
