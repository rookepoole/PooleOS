{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pgb2-trap-execution.schema.json",
  "title": "PooleOS PGB2 Trap Execution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "execution_version",
    "encoding_artifact",
    "security_boundary_claimed",
    "program",
    "executed_instructions",
    "decode_errors",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.pgb2_trap_execution"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "execution_version": {
      "type": "string"
    },
    "encoding_artifact": {
      "type": "object",
      "required": [
        "artifact_path",
        "status",
        "encoding_version",
        "instruction_count",
        "byte_length",
        "sha256",
        "matrix_bound",
        "fuzz_bound",
        "core_ir_boundary_status",
        "core_ir_binding_mode",
        "parser_kernel_promotion_receipt_bound",
        "parser_kernel_promotion_receipt_status",
        "parser_kernel_promotion_kernel_handoff_allowed",
        "parser_to_kernel_promotion_allowed",
        "kernel_enforcement_claimed",
        "failed_check_count"
      ],
      "properties": {
        "artifact_path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "encoding_version": {
          "type": "string"
        },
        "instruction_count": {
          "type": "integer"
        },
        "byte_length": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "matrix_bound": {
          "type": "boolean"
        },
        "fuzz_bound": {
          "type": "boolean"
        },
        "core_ir_boundary_status": {
          "type": "string"
        },
        "core_ir_binding_mode": {
          "type": "string"
        },
        "parser_kernel_promotion_receipt_bound": {
          "type": "boolean"
        },
        "parser_kernel_promotion_receipt_status": {
          "type": "string"
        },
        "parser_kernel_promotion_kernel_handoff_allowed": {
          "type": "boolean"
        },
        "parser_to_kernel_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        },
        "failed_check_count": {
          "type": "integer"
        }
      }
    },
    "security_boundary_claimed": {
      "type": "boolean"
    },
    "program": {
      "type": "object",
      "required": [
        "decoded_instruction_count",
        "byte_length",
        "sha256",
        "all_bytes_consumed"
      ],
      "properties": {
        "decoded_instruction_count": {
          "type": "integer"
        },
        "byte_length": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "all_bytes_consumed": {
          "type": "boolean"
        }
      }
    },
    "executed_instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "index",
          "source_instruction_index",
          "operation_opcode",
          "region",
          "source",
          "target",
          "capability",
          "expected_trap",
          "expected_trap_code",
          "actual_trapped",
          "actual_trap_code",
          "outcome_match",
          "instruction_order_match",
          "instruction_bytes_match",
          "byte_offset",
          "byte_length"
        ],
        "properties": {
          "index": {
            "type": "integer"
          },
          "source_instruction_index": {
            "type": "integer"
          },
          "case_id": {
            "type": "string"
          },
          "fuzz_kind": {
            "type": "string"
          },
          "operation_opcode": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "capability": {
            "type": "string"
          },
          "expected_trap": {
            "type": "boolean"
          },
          "expected_trap_code": {
            "type": "string"
          },
          "actual_trapped": {
            "type": "boolean"
          },
          "actual_trap_code": {
            "type": "string"
          },
          "outcome_match": {
            "type": "boolean"
          },
          "instruction_order_match": {
            "type": "boolean"
          },
          "instruction_bytes_match": {
            "type": "boolean"
          },
          "byte_offset": {
            "type": "integer"
          },
          "byte_length": {
            "type": "integer"
          }
        }
      }
    },
    "decode_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "encoded_instruction_count",
        "executed_instruction_count",
        "allowed_count",
        "trapped_count",
        "matrix_instruction_count",
        "fuzz_instruction_count",
        "byte_length",
        "decode_error_count",
        "outcome_mismatch_count",
        "failed_check_count"
      ],
      "properties": {
        "encoded_instruction_count": {
          "type": "integer"
        },
        "executed_instruction_count": {
          "type": "integer"
        },
        "allowed_count": {
          "type": "integer"
        },
        "trapped_count": {
          "type": "integer"
        },
        "matrix_instruction_count": {
          "type": "integer"
        },
        "fuzz_instruction_count": {
          "type": "integer"
        },
        "byte_length": {
          "type": "integer"
        },
        "decode_error_count": {
          "type": "integer"
        },
        "outcome_mismatch_count": {
          "type": "integer"
        },
        "failed_check_count": {
          "type": "integer"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
