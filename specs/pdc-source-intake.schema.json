{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pdc-source-intake.schema.json",
  "title": "PooleOS PDC Source Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "created_utc",
    "status",
    "scope",
    "designated_sources",
    "raw_artifact_candidates",
    "digests",
    "summary",
    "limitations"
  ],
  "properties": {
    "schema_version": {"const": "0.1"},
    "artifact_kind": {"const": "pdc_source_intake"},
    "created_utc": {"type": "string", "minLength": 20},
    "status": {"enum": ["pass", "fail"]},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designated_authority_count",
        "raw_scan_root",
        "raw_scan_depth",
        "raw_extensions",
        "raw_name_pattern",
        "raw_candidates_are_authoritative"
      ],
      "properties": {
        "designated_authority_count": {"const": 7},
        "raw_scan_root": {"type": "string", "minLength": 3},
        "raw_scan_depth": {"const": 1},
        "raw_extensions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^\\."},
          "uniqueItems": true
        },
        "raw_name_pattern": {"type": "string", "minLength": 10},
        "raw_candidates_are_authoritative": {"const": false}
      }
    },
    "designated_sources": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {"$ref": "#/$defs/designated_source"}
    },
    "raw_artifact_candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/raw_candidate"}
    },
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["designated_source_set_sha256", "raw_candidate_index_sha256"],
      "properties": {
        "designated_source_set_sha256": {"$ref": "#/$defs/sha256"},
        "raw_candidate_index_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locked_source_count",
        "verified_copy_count",
        "raw_candidate_count",
        "raw_duplicate_count",
        "raw_imported_count",
        "failed_count"
      ],
      "properties": {
        "locked_source_count": {"const": 7},
        "verified_copy_count": {"const": 7},
        "raw_candidate_count": {"type": "integer", "minimum": 0},
        "raw_duplicate_count": {"type": "integer", "minimum": 0},
        "raw_imported_count": {"type": "integer", "minimum": 0},
        "failed_count": {"const": 0}
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string", "minLength": 10},
      "uniqueItems": true
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9A-F]{64}$"
    },
    "designated_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "original_name",
        "original_path",
        "stored_path",
        "kind",
        "size_bytes",
        "modified_utc",
        "sha256",
        "claim_role",
        "status"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^SRC-[A-Z]+-[0-9]+$"},
        "original_name": {"type": "string", "minLength": 3},
        "original_path": {"type": "string", "minLength": 3},
        "stored_path": {"type": "string", "pattern": "^sources/pdc/intake/sha256/[0-9a-f]{64}\\.(md|pdf)$"},
        "kind": {"enum": ["markdown", "pdf"]},
        "size_bytes": {"type": "integer", "minimum": 1},
        "modified_utc": {"type": "string", "minLength": 20},
        "sha256": {"$ref": "#/$defs/sha256"},
        "claim_role": {"type": "string", "minLength": 10},
        "status": {"const": "locked_copy_verified"}
      }
    },
    "raw_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "size_bytes", "modified_utc", "sha256", "duplicate_of", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^RAW-PDC-[0-9]{3}$"},
        "name": {"type": "string", "minLength": 3},
        "path": {"type": "string", "minLength": 3},
        "size_bytes": {"type": "integer", "minimum": 1},
        "modified_utc": {"type": "string", "minLength": 20},
        "sha256": {"$ref": "#/$defs/sha256"},
        "duplicate_of": {
          "anyOf": [
            {"type": "null"},
            {"type": "string", "minLength": 3}
          ]
        },
        "status": {"const": "indexed_not_imported"}
      }
    }
  }
}
