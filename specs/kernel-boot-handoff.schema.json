{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/kernel-boot-handoff.schema.json",
  "title": "PooleOS Kernel Boot Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "kernel_handoff_allowed",
    "kernel_boundary_claimed",
    "pgvm2_execution_claimed",
    "sources",
    "marker_level_evidence",
    "guest_loader_outputs",
    "handoff_requirements",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.kernel_boot_handoff"
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked",
        "ready_for_kernel_handoff",
        "invalid"
      ]
    },
    "kernel_handoff_allowed": {
      "type": "boolean"
    },
    "kernel_boundary_claimed": {
      "type": "boolean"
    },
    "pgvm2_execution_claimed": {
      "type": "boolean"
    },
    "sources": {
      "type": "object",
      "required": [
        "qemu_captured_boot_readiness",
        "qemu_boot_marker_contract",
        "boot_trap_bundle_manifest",
        "guest_loader_verification"
      ],
      "properties": {
        "qemu_captured_boot_readiness": {
          "$ref": "#/$defs/source"
        },
        "qemu_boot_marker_contract": {
          "$ref": "#/$defs/source"
        },
        "boot_trap_bundle_manifest": {
          "$ref": "#/$defs/source"
        },
        "guest_loader_verification": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "marker_level_evidence": {
      "type": "object",
      "required": [
        "captured_readiness_status",
        "promotion_language_allowed",
        "marker_contract_status",
        "marker_count",
        "boot_evidence_claimed_by_marker_contract",
        "claim_boundary"
      ],
      "properties": {
        "captured_readiness_status": {
          "type": "string"
        },
        "promotion_language_allowed": {
          "type": "boolean"
        },
        "marker_contract_status": {
          "type": "string"
        },
        "marker_count": {
          "type": "integer"
        },
        "boot_evidence_claimed_by_marker_contract": {
          "type": "boolean"
        },
        "claim_boundary": {
          "type": "string"
        }
      }
    },
    "guest_loader_outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/guest_loader_output"
      }
    },
    "handoff_requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "failed_check_count",
        "unmet_requirement_count",
        "captured_readiness_status",
        "marker_contract_status",
        "boot_manifest_status",
        "guest_loader_verification_exists",
        "guest_loader_verification_status",
        "kernel_handoff_allowed",
        "kernel_boundary_claimed",
        "pgvm2_execution_claimed"
      ],
      "properties": {
        "failed_check_count": {
          "type": "integer"
        },
        "unmet_requirement_count": {
          "type": "integer"
        },
        "captured_readiness_status": {
          "type": "string"
        },
        "marker_contract_status": {
          "type": "string"
        },
        "boot_manifest_status": {
          "type": "string"
        },
        "guest_loader_verification_exists": {
          "type": "boolean"
        },
        "guest_loader_verification_status": {
          "type": "string"
        },
        "kernel_handoff_allowed": {
          "type": "boolean"
        },
        "kernel_boundary_claimed": {
          "type": "boolean"
        },
        "pgvm2_execution_claimed": {
          "type": "boolean"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "artifact_kind",
        "status"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "guest_loader_output": {
      "type": "object",
      "required": [
        "role",
        "guest_path",
        "host_capture_path",
        "exists",
        "artifact_kind",
        "status",
        "expected_executed_instruction_count",
        "actual_executed_instruction_count",
        "required_for_kernel_handoff"
      ],
      "properties": {
        "role": {
          "type": "string"
        },
        "guest_path": {
          "type": "string"
        },
        "host_capture_path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "expected_executed_instruction_count": {
          "type": "integer"
        },
        "actual_executed_instruction_count": {
          "type": "integer"
        },
        "required_for_kernel_handoff": {
          "type": "boolean"
        }
      }
    },
    "requirement": {
      "type": "object",
      "required": [
        "name",
        "met",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "met": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "check": {
      "type": "object",
      "required": [
        "name",
        "ok",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
