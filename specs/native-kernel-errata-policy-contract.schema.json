{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/schemas/native-kernel-errata-policy-contract.schema.json",
  "title": "PooleOS PKERR1 target errata policy contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "selected_move_id",
    "status_date",
    "status",
    "production_ready",
    "production_promotion_allowed",
    "phase_mapping",
    "source_requirement_ids",
    "target",
    "mandatory_features",
    "firmware_policy",
    "microcode_policy",
    "rdseed_policy",
    "errata_policy",
    "source_register",
    "current_observation",
    "authority_gate",
    "claims",
    "required_negative_controls",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_errata_policy_contract"},
    "contract_id": {"const": "PKERR1"},
    "selected_move_id": {"const": "N7-ERRATA-POLICY-001"},
    "status_date": {"type": "string", "format": "date"},
    "status": {"const": "candidate_fail_closed_target_errata_policy_non_promoting"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "phase_mapping": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "string"}},
    "source_requirement_ids": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "string"}},
    "target": {"type": "object"},
    "mandatory_features": {"type": "object"},
    "firmware_policy": {"type": "object"},
    "microcode_policy": {"type": "object"},
    "rdseed_policy": {"type": "object"},
    "errata_policy": {"type": "object"},
    "source_register": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"type": "object"}},
    "current_observation": {"type": "object"},
    "authority_gate": {"type": "object"},
    "claims": {"type": "object"},
    "required_negative_controls": {"type": "array", "minItems": 24, "maxItems": 24, "uniqueItems": true, "items": {"type": "string"}},
    "non_claims": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "string"}}
  }
}
