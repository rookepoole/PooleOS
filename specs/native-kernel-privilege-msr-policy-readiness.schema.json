{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.example/specs/native-kernel-privilege-msr-policy-readiness.schema.json",
  "title": "PooleOS PKMSR1 readiness",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n7_exit_gate_satisfied",
    "phase_status",
    "inputs",
    "build",
    "media",
    "execution",
    "negative_controls",
    "claims",
    "non_claims",
    "summary",
    "open_items"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_privilege_msr_policy_readiness"},
    "status_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "status": {"const": "pass_single_host_two_run_qemu64_read_only_non_promoting"},
    "contract_id": {"const": "PKMSR1"},
    "selected_move_id": {"const": "N7-PRIVILEGE-MSR-POLICY-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n7_exit_gate_satisfied": {"const": false},
    "phase_status": {"type": "object"},
    "inputs": {"type": "object"},
    "build": {"type": "object"},
    "media": {"type": "object"},
    "execution": {
      "type": "object",
      "required": ["run_count", "exact_marker_match", "exact_screenshot_match", "exact_pbp1_match", "runs", "observation"],
      "properties": {
        "run_count": {"const": 2},
        "exact_marker_match": {"const": true},
        "exact_screenshot_match": {"const": true},
        "exact_pbp1_match": {"const": true},
        "runs": {"type": "array", "minItems": 2, "maxItems": 2},
        "observation": {"type": "object"}
      }
    },
    "negative_controls": {
      "type": "array",
      "minItems": 47,
      "maxItems": 47,
      "items": {
        "type": "object",
        "required": ["id", "status", "expected"],
        "properties": {
          "id": {"type": "string"},
          "status": {"const": "pass"},
          "expected": {"const": "rejected"}
        }
      }
    },
    "claims": {"type": "object"},
    "non_claims": {"type": "array", "items": {"type": "string"}},
    "summary": {"type": "object"},
    "open_items": {"type": "array", "items": {"type": "string"}}
  }
}
