{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "status",
    "inputs",
    "build",
    "golden",
    "negative_controls",
    "differential",
    "development_integration",
    "backend_model",
    "claims",
    "non_claims",
    "production_ready"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "pooleos_native_boot_trust_readiness"},
    "contract_id": {"const": "PBTRUST1"},
    "status": {"const": "pass"},
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "toolchain_lock", "toolchain_qualification", "tier1_profile", "implementation_inputs"],
      "properties": {
        "contract": {"$ref": "#/$defs/binding"},
        "toolchain_lock": {"$ref": "#/$defs/binding"},
        "toolchain_qualification": {"$ref": "#/$defs/binding"},
        "tier1_profile": {"$ref": "#/$defs/binding"},
        "implementation_inputs": {"type": "array", "minItems": 16, "maxItems": 16, "items": {"$ref": "#/$defs/binding"}}
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rustc", "rust_host_tests_passed", "rust_host_tests_total", "rustfmt_packages", "clippy_targets", "no_std_targets", "pooleboot_uefi_integration_builds_passed", "pooleboot_uefi_integration_builds_total"],
      "properties": {
        "rustc": {"type": "string"},
        "rust_host_tests_passed": {"const": 12},
        "rust_host_tests_total": {"const": 12},
        "rustfmt_packages": {"const": 1},
        "clippy_targets": {"const": 1},
        "no_std_targets": {"const": ["x86_64-unknown-none", "x86_64-unknown-uefi"]},
        "pooleboot_uefi_integration_builds_passed": {"const": 1},
        "pooleboot_uefi_integration_builds_total": {"const": 1}
      }
    },
    "golden": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_count", "development_policy_sha256", "development_state_sha256", "signed_shape_policy_sha256", "authenticated_shape_state_sha256", "generation_two_state_sha256", "backend_copy_zero_sha256", "backend_copy_one_sha256", "backend_logical_state_sha256", "synthetic_authorization_model_result"],
      "properties": {
        "case_count": {"const": 5},
        "development_policy_sha256": {"$ref": "#/$defs/sha256"},
        "development_state_sha256": {"$ref": "#/$defs/sha256"},
        "signed_shape_policy_sha256": {"$ref": "#/$defs/sha256"},
        "authenticated_shape_state_sha256": {"$ref": "#/$defs/sha256"},
        "generation_two_state_sha256": {"$ref": "#/$defs/sha256"},
        "backend_copy_zero_sha256": {"$ref": "#/$defs/sha256"},
        "backend_copy_one_sha256": {"$ref": "#/$defs/sha256"},
        "backend_logical_state_sha256": {"$ref": "#/$defs/sha256"},
        "synthetic_authorization_model_result": {"const": "qualified_shape_only_no_crypto_claim"}
      }
    },
    "negative_controls": {"type": "array", "minItems": 105, "maxItems": 105, "items": {"$ref": "#/$defs/control"}},
    "differential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_parser", "state_parser", "authorization", "backend_selection"],
      "properties": {
        "policy_parser": {"$ref": "#/$defs/differential"},
        "state_parser": {"$ref": "#/$defs/differential"},
        "authorization": {"$ref": "#/$defs/differential"},
        "backend_selection": {"$ref": "#/$defs/differential"}
      }
    },
    "development_integration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_bytes", "state_bytes", "binding_count", "denial_count", "denial", "state_source", "state_authenticated", "state_monotonic", "state_backend_writable", "signature_verifications", "authority_grants", "state_writes"],
      "properties": {
        "policy_bytes": {"const": 320},
        "state_bytes": {"const": 256},
        "binding_count": {"const": 14},
        "denial_count": {"const": 1},
        "denial": {"const": "pbtrust_policy_unsigned"},
        "state_source": {"const": "esp_candidate_not_persistent_authority"},
        "state_authenticated": {"const": false},
        "state_monotonic": {"const": false},
        "state_backend_writable": {"const": false},
        "signature_verifications": {"const": 0},
        "authority_grants": {"const": 0},
        "state_writes": {"const": 0}
      }
    },
    "backend_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_id", "logical_digest_domain", "selected_copy", "anchored_copy_mask", "repair_copy_mask", "migration_required", "next_generation", "target_copy", "ordered_transition_steps", "authority_grants", "state_writes_performed", "anchor_writes_performed", "power_loss"],
      "properties": {
        "contract_id": {"const": "PBSTATE1"},
        "logical_digest_domain": {"const": "POOLEOS/PBTS1/LOGICAL/V1"},
        "selected_copy": {"const": 0},
        "anchored_copy_mask": {"const": 3},
        "repair_copy_mask": {"const": 0},
        "migration_required": {"const": true},
        "next_generation": {"const": 2},
        "target_copy": {"const": 1},
        "ordered_transition_steps": {"const": ["write_target_uncommitted", "flush_target_data", "write_target_commit_and_authentication", "flush_target_commit", "advance_monotonic_anchor", "verify_monotonic_anchor", "repair_other_copy", "flush_repaired_copy", "verify_redundant_copies"]},
        "authority_grants": {"const": 0},
        "state_writes_performed": {"const": 0},
        "anchor_writes_performed": {"const": 0},
        "power_loss": {
          "type": "object",
          "additionalProperties": false,
          "required": ["case_count", "all_cases_passed", "storage_io_performed", "anchor_writes_performed", "state_writes_performed", "cases"],
          "properties": {
            "case_count": {"const": 9},
            "all_cases_passed": {"const": true},
            "storage_io_performed": {"const": false},
            "anchor_writes_performed": {"const": 0},
            "state_writes_performed": {"const": 0},
            "cases": {"type": "array", "minItems": 9, "maxItems": 9, "items": {"$ref": "#/$defs/power_case"}}
          }
        }
      }
    },
    "claims": {"type": "object"},
    "non_claims": {"type": "array", "minItems": 7, "items": {"type": "string"}},
    "production_ready": {"const": false}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "byte_count", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "byte_count": {"type": "integer", "minimum": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "expected", "python", "rust", "status"],
      "properties": {
        "id": {"type": "string", "pattern": "^NEG-N5-PBTRUST-"},
        "expected": {"type": "string", "pattern": "^(ERR:pbtrust_|OK;)"},
        "python": {"type": "string"},
        "rust": {"type": "string"},
        "status": {"const": "pass"}
      }
    },
    "differential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases", "mismatches", "seed"],
      "properties": {
        "cases": {"const": 8192},
        "mismatches": {"const": 0},
        "seed": {"type": "integer", "minimum": 1}
      }
    },
    "power_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selected_generation", "selected_copy", "repair_copy_mask", "authority_grants", "state_writes", "status"],
      "properties": {
        "id": {"enum": ["before_target_write", "after_target_body_write", "after_target_data_flush", "after_target_commit_auth", "after_target_commit_flush", "after_anchor_advance", "after_anchor_verify", "after_repair_write", "after_final_verify"]},
        "selected_generation": {"type": "integer", "minimum": 1, "maximum": 2},
        "selected_copy": {"type": "integer", "minimum": 0, "maximum": 1},
        "repair_copy_mask": {"type": "integer", "minimum": 0, "maximum": 3},
        "authority_grants": {"const": 0},
        "state_writes": {"const": 0},
        "status": {"const": "pass"}
      }
    }
  }
}
