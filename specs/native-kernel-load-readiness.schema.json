{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-kernel-load-readiness.schema.json",
  "title": "PooleOS PKLOAD6 readiness",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n5_exit_gate_satisfied",
    "phase_status",
    "bindings",
    "host_tests",
    "build",
    "kernel_product",
    "media",
    "execution",
    "oracle",
    "cleanup",
    "negative_controls",
    "claims",
    "summary",
    "open_items",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_load_readiness"},
    "status_date": {"const": "2026-07-18"},
    "status": {"const": "pass_single_host_two_run_live_pbart1_pkmap2_exit_then_stop_non_promoting"},
    "contract_id": {"const": "PKLOAD6"},
    "selected_move_id": {"const": "N5-RECOVERY-SEMANTICS-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n5_exit_gate_satisfied": {"const": false},
    "phase_status": {
      "type": "object",
      "required": ["N5", "N5.1", "N5.4", "N5.5", "N5.6", "N5.8", "N5.9"],
      "properties": {
        "N5": {"const": "partial"},
        "N5.1": {"const": "partial"},
        "N5.4": {"const": "partial"},
        "N5.5": {"const": "partial"},
        "N5.6": {"const": "partial"},
        "N5.8": {"const": "partial"},
        "N5.9": {"const": "partial"}
      }
    },
    "bindings": {
      "type": "object",
      "required": ["contract", "kernel_map_contract", "boot_exit_contract", "toolchain_lock", "toolchain_qualification", "tier0_lock", "tier0_profile", "tier0_readiness", "kernel_entry_contract", "kernel_entry_readiness", "system_manifest_contract", "system_manifest_readiness", "digest_provider", "initial_system_contract", "initial_system_readiness", "recovery_contract", "recovery_readiness", "implementation_inputs"],
      "properties": {
        "contract": {"$ref": "#/$defs/binding"},
        "kernel_map_contract": {"$ref": "#/$defs/binding"},
        "boot_exit_contract": {"$ref": "#/$defs/binding"},
        "toolchain_lock": {"$ref": "#/$defs/binding"},
        "toolchain_qualification": {"$ref": "#/$defs/binding"},
        "tier0_lock": {"$ref": "#/$defs/binding"},
        "tier0_profile": {"$ref": "#/$defs/binding"},
        "tier0_readiness": {"$ref": "#/$defs/binding"},
        "kernel_entry_contract": {"$ref": "#/$defs/binding"},
        "kernel_entry_readiness": {"$ref": "#/$defs/binding"},
        "system_manifest_contract": {"$ref": "#/$defs/binding"},
        "system_manifest_readiness": {"$ref": "#/$defs/binding"},
        "digest_provider": {"$ref": "#/$defs/binding"},
        "initial_system_contract": {"$ref": "#/$defs/binding"},
        "initial_system_readiness": {"$ref": "#/$defs/binding"},
        "recovery_contract": {"$ref": "#/$defs/binding"},
        "recovery_readiness": {"$ref": "#/$defs/binding"},
        "implementation_inputs": {"type": "array", "minItems": 82, "maxItems": 82, "items": {"$ref": "#/$defs/binding"}}
      }
    },
    "host_tests": {
      "type": "object",
      "required": ["bootload_tests_passed", "bootload_tests_total", "artifact_tests_passed", "artifact_tests_total", "artifact_differential_cases", "handoff_tests_passed", "handoff_tests_total", "live_handoff_tests_passed", "live_handoff_tests_total", "kernel_map_tests_passed", "kernel_map_tests_total", "boot_exit_tests_passed", "boot_exit_tests_total", "kernel_map_probe", "pooleboot_tests_passed", "pooleboot_tests_total", "kernel_entry_tests_passed", "kernel_entry_tests_total", "rustfmt_passed", "clippy_passed"],
      "properties": {
        "bootload_tests_passed": {"minimum": 16},
        "bootload_tests_total": {"minimum": 16},
        "artifact_tests_passed": {"minimum": 4},
        "artifact_tests_total": {"minimum": 4},
        "artifact_differential_cases": {"const": 7},
        "handoff_tests_passed": {"minimum": 8},
        "handoff_tests_total": {"minimum": 8},
        "live_handoff_tests_passed": {"minimum": 8},
        "live_handoff_tests_total": {"minimum": 8},
        "kernel_map_tests_passed": {"minimum": 14},
        "kernel_map_tests_total": {"minimum": 14},
        "boot_exit_tests_passed": {"minimum": 5},
        "boot_exit_tests_total": {"minimum": 5},
        "kernel_map_probe": {"type": "object", "required": ["contract_id", "kernel_page_count", "stack_page_count", "handoff_page_count", "retained_leaf_fingerprint"]},
        "pooleboot_tests_passed": {"minimum": 8},
        "pooleboot_tests_total": {"minimum": 8},
        "kernel_entry_tests_passed": {"minimum": 13},
        "kernel_entry_tests_total": {"minimum": 13},
        "rustfmt_passed": {"const": true},
        "clippy_passed": {"const": true}
      }
    },
    "build": {
      "type": "object",
      "required": ["clean_build_count", "exact_clean_build_match", "sha256", "byte_count"],
      "properties": {
        "clean_build_count": {"const": 2},
        "exact_clean_build_match": {"const": true},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_count": {"type": "integer", "minimum": 1, "maximum": 262144}
      }
    },
    "media": {
      "type": "object",
      "required": ["clean_generation_count", "exact_clean_generation_match", "ordinary_workspace_file_only", "physical_media_write_performed", "inspection"],
      "properties": {
        "clean_generation_count": {"const": 2},
        "exact_clean_generation_match": {"const": true},
        "ordinary_workspace_file_only": {"const": true},
        "physical_media_write_performed": {"const": false},
        "inspection": {
          "type": "object",
          "required": ["files", "manifest", "kernel", "artifact_set", "initial_system", "recovery"],
          "properties": {
            "files": {"type": "array", "minItems": 10, "maxItems": 10},
            "artifact_set": {
              "type": "object",
              "required": ["contract_id", "artifact_count", "file_bytes", "page_count", "fnv1a64", "signatures_verified", "measured", "semantics_applied", "artifacts"],
              "properties": {
                "contract_id": {"const": "PBART1"},
                "artifact_count": {"const": 6},
                "file_bytes": {"type": "integer", "minimum": 6},
                "page_count": {"type": "integer", "minimum": 6},
                "signatures_verified": {"const": false},
                "measured": {"const": false},
                "semantics_applied": {"const": false},
                "artifacts": {"type": "array", "minItems": 6, "maxItems": 6}
              }
            },
            "initial_system": {
              "type": "object",
              "required": ["contract_id", "summary", "bundle_sha256", "bundle_version", "component_count", "service_count", "dependency_count", "resource_count", "capability_count", "start_order", "outer_payload_sha256", "activation_allowed", "activation_errors", "validated_by", "pooleboot_enforced", "poolekernel_enforced"],
              "properties": {
                "contract_id": {"const": "PINIT1"},
                "bundle_version": {"const": 1},
                "component_count": {"const": 3},
                "service_count": {"const": 3},
                "dependency_count": {"const": 3},
                "resource_count": {"const": 4},
                "capability_count": {"const": 11},
                "start_order": {"const": [1, 2, 3]},
                "activation_allowed": {"const": false},
                "activation_errors": {"type": "array", "minItems": 1},
                "validated_by": {"const": "independent_host_media_oracle"},
                "pooleboot_enforced": {"const": false},
                "poolekernel_enforced": {"const": false}
              }
            },
            "recovery": {
              "type": "object",
              "required": ["contract_id", "summary", "bundle_sha256", "bundle_version", "slot_count", "failure_rule_count", "authority_rule_count", "max_attempts", "mutable_state_bytes", "outer_payload_sha256", "activation_allowed", "activation_errors", "validated_by", "pooleboot_enforced", "poolekernel_enforced", "recovery_executed"],
              "properties": {
                "contract_id": {"const": "PREC1"},
                "bundle_version": {"const": 1},
                "slot_count": {"const": 2},
                "failure_rule_count": {"const": 10},
                "authority_rule_count": {"const": 7},
                "max_attempts": {"const": 3},
                "mutable_state_bytes": {"const": 128},
                "activation_allowed": {"const": false},
                "activation_errors": {"type": "array", "minItems": 1},
                "validated_by": {"const": "independent_host_media_oracle"},
                "pooleboot_enforced": {"const": false},
                "poolekernel_enforced": {"const": false},
                "recovery_executed": {"const": false}
              }
            }
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "required": ["host_environment_count", "run_count", "profile_id", "machine", "exact_marker_match", "exact_screenshot_match", "runs"],
      "properties": {
        "host_environment_count": {"const": 1},
        "run_count": {"const": 2},
        "profile_id": {"const": "bootstrap-debug"},
        "machine": {"const": "pc-q35-11.0"},
        "exact_marker_match": {"const": true},
        "exact_screenshot_match": {"const": true},
        "runs": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/run"}}
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": {"const": true},
      "required": ["pbc1_python_match", "psm1_python_match", "pbart1_python_match", "pbart1_rust_python_match", "pbart1_manifest_cross_binding", "pbp1_profile_artifact_cross_binding", "sha256_python_match", "pkelf1_python_plan_match", "pbp1_python_decode_match", "pkmap2_rust_python_probe_match", "pbexit1_final_map_attempt_match", "media_reconstruction_exact"],
      "minProperties": 26
    },
    "cleanup": {
      "type": "object",
      "required": ["file_handles_closed", "file_pools_freed", "kmap_table_pages_retained", "stack_pages_retained", "handoff_pages_retained", "artifact_pages_retained", "firmware_calls_after_exit", "pages_freed", "all_resources_released"],
      "properties": {
        "file_handles_closed": {"const": 10},
        "file_pools_freed": {"const": 9},
        "kmap_table_pages_retained": {"const": 4},
        "stack_pages_retained": {"const": 8},
        "handoff_pages_retained": {"const": 256},
        "artifact_pages_retained": {"type": "integer", "minimum": 6},
        "firmware_calls_after_exit": {"const": 0},
        "pages_freed": {"const": false},
        "all_resources_released": {"const": false}
      }
    },
    "negative_controls": {"type": "array", "minItems": 118, "maxItems": 118, "items": {"$ref": "#/$defs/control"}},
    "claims": {"type": "object", "minProperties": 67, "maxProperties": 67},
    "summary": {"type": "object"},
    "open_items": {"type": "array", "minItems": 8, "items": {"type": "string"}},
    "claim_boundary": {"type": "array", "minItems": 10, "items": {"type": "string"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_count"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_count": {"type": "integer", "minimum": 1}
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "expected", "observed", "status"],
      "properties": {
        "id": {"type": "string"},
        "expected": {"const": "reject"},
        "observed": {"const": "reject"},
        "status": {"const": "pass"}
      }
    },
    "run": {
      "type": "object",
      "required": ["markers", "marker_sha256", "marker_summary", "serial_debugcon_exact_match", "pbp1_transcript", "pbp1_serial_debugcon_exact_match", "screenshot", "qemu_exit_code"],
      "properties": {
        "markers": {"type": "array", "minItems": 23, "maxItems": 23, "items": {"type": "string"}},
        "marker_sha256": {"$ref": "#/$defs/sha256"},
        "serial_debugcon_exact_match": {"const": true},
        "pbp1_transcript": {
          "type": "object",
          "required": ["contract_id", "byte_count", "sha256", "record_count", "memory_entry_count", "artifacts", "exit_development_profile_validated", "kernel_entry_profile_rejected"],
          "properties": {
            "artifacts": {"type": "array", "minItems": 7, "maxItems": 7},
            "exit_development_profile_validated": {"const": true},
            "kernel_entry_profile_rejected": {"const": true}
          }
        },
        "pbp1_serial_debugcon_exact_match": {"const": true},
        "qemu_exit_code": {"const": 0}
      }
    }
  }
}
