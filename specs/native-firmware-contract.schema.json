{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "contract_id", "version", "profile", "format", "limits", "header_flags", "component_flags", "transports", "activation_error_order", "post_reset_error_order", "claims", "non_claims", "primary_references", "implementation_bindings"],
  "properties": {
    "schema_version": {"const": 1},
    "artifact_kind": {"const": "pooleos_native_firmware_contract"},
    "contract_id": {"const": "PFWM1"},
    "version": {"type": "object"},
    "profile": {"const": "synthetic_qualification_never_apply"},
    "format": {"type": "object"},
    "limits": {"type": "object"},
    "header_flags": {"type": "array", "minItems": 20, "uniqueItems": true, "items": {"type": "string"}},
    "component_flags": {"type": "array", "minItems": 19, "uniqueItems": true, "items": {"type": "string"}},
    "transports": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string"}},
    "activation_error_order": {"type": "array", "minItems": 40, "uniqueItems": true, "items": {"type": "string", "pattern": "^pfwm_activation_"}},
    "post_reset_error_order": {"type": "array", "minItems": 15, "uniqueItems": true, "items": {"type": "string", "pattern": "^pfwm_post_reset_"}},
    "claims": {"type": "object"},
    "non_claims": {"type": "array", "minItems": 5, "items": {"type": "string"}},
    "primary_references": {"type": "array", "minItems": 4, "items": {"type": "string", "format": "uri"}},
    "implementation_bindings": {"type": "array", "minItems": 10, "items": {"$ref": "#/$defs/binding"}}
  },
  "$defs": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "bytes": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"}
      }
    }
  }
}
