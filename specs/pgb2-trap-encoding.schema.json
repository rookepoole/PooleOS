{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pgb2-trap-encoding.schema.json",
  "title": "PooleOS PGB2 Trap Encoding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "encoding_version",
    "source_trap_proof",
    "opcode_table",
    "program",
    "instructions",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.pgb2_trap_encoding"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "fail"
      ]
    },
    "encoding_version": {
      "type": "string"
    },
    "source_trap_proof": {
      "type": "object",
      "required": [
        "artifact_path",
        "status",
        "operation_count",
        "failed_check_count",
        "matrix_bound",
        "fuzz_bound",
        "core_ir_boundary_status",
        "core_ir_binding_mode",
        "core_ir_executable_audit_bound",
        "core_ir_executable_audit_status",
        "core_ir_executable_candidate_count",
        "core_ir_metadata_zero_count",
        "core_ir_kernel_handoff_allowed",
        "parser_kernel_promotion_receipt_bound",
        "parser_kernel_promotion_receipt_status",
        "parser_kernel_promotion_kernel_handoff_allowed",
        "parser_to_kernel_promotion_allowed",
        "kernel_enforcement_claimed"
      ],
      "properties": {
        "artifact_path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "operation_count": {
          "type": "integer"
        },
        "failed_check_count": {
          "type": "integer"
        },
        "matrix_bound": {
          "type": "boolean"
        },
        "fuzz_bound": {
          "type": "boolean"
        },
        "core_ir_boundary_status": {
          "type": "string"
        },
        "core_ir_binding_mode": {
          "type": "string"
        },
        "core_ir_executable_audit_bound": {
          "type": "boolean"
        },
        "core_ir_executable_audit_status": {
          "type": "string"
        },
        "core_ir_executable_candidate_count": {
          "type": "integer"
        },
        "core_ir_metadata_zero_count": {
          "type": "integer"
        },
        "core_ir_kernel_handoff_allowed": {
          "type": "boolean"
        },
        "parser_kernel_promotion_receipt_bound": {
          "type": "boolean"
        },
        "parser_kernel_promotion_receipt_status": {
          "type": "string"
        },
        "parser_kernel_promotion_kernel_handoff_allowed": {
          "type": "boolean"
        },
        "parser_to_kernel_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        }
      }
    },
    "opcode_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "operation_opcode",
          "encoded_opcode_hex",
          "operand_layout"
        ],
        "properties": {
          "operation_opcode": {
            "type": "string"
          },
          "encoded_opcode_hex": {
            "type": "string"
          },
          "operand_layout": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "program": {
      "type": "object",
      "required": [
        "instruction_count",
        "byte_length",
        "raw_hex",
        "sha256"
      ],
      "properties": {
        "instruction_count": {
          "type": "integer"
        },
        "byte_length": {
          "type": "integer"
        },
        "raw_hex": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "index",
          "source_operation_index",
          "operation_opcode",
          "encoded_opcode_hex",
          "byte_length",
          "encoded_hex",
          "encoded_sha256",
          "expected_trap",
          "expected_trap_code",
          "decoded_operands",
          "roundtrip_ok"
        ],
        "properties": {
          "index": {
            "type": "integer"
          },
          "source_operation_index": {
            "type": "integer"
          },
          "case_id": {
            "type": "string"
          },
          "fuzz_kind": {
            "type": "string"
          },
          "operation_opcode": {
            "type": "string"
          },
          "encoded_opcode_hex": {
            "type": "string"
          },
          "byte_length": {
            "type": "integer"
          },
          "encoded_hex": {
            "type": "string"
          },
          "encoded_sha256": {
            "type": "string"
          },
          "expected_trap": {
            "type": "boolean"
          },
          "expected_trap_code": {
            "type": "string"
          },
          "decoded_operands": {
            "type": "object"
          },
          "roundtrip_ok": {
            "type": "boolean"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ok",
          "detail"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "source_operation_count",
        "instruction_count",
        "byte_length",
        "allowed_instruction_count",
        "trapped_instruction_count",
        "matrix_instruction_count",
        "fuzz_instruction_count",
        "failed_check_count"
      ],
      "properties": {
        "source_operation_count": {
          "type": "integer"
        },
        "instruction_count": {
          "type": "integer"
        },
        "byte_length": {
          "type": "integer"
        },
        "allowed_instruction_count": {
          "type": "integer"
        },
        "trapped_instruction_count": {
          "type": "integer"
        },
        "matrix_instruction_count": {
          "type": "integer"
        },
        "fuzz_instruction_count": {
          "type": "integer"
        },
        "failed_check_count": {
          "type": "integer"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
