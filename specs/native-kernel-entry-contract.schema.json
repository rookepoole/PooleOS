{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-kernel-entry-contract.schema.json",
  "title": "PooleOS native PKENTRY1 contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "selected_move_id",
    "status_date",
    "status",
    "production_ready",
    "production_promotion_allowed",
    "phase_mapping",
    "source_requirement_ids",
    "authorities",
    "product",
    "build_profile",
    "transfer",
    "mapping_preconditions",
    "intake",
    "early_diagnostics",
    "panic_profile",
    "required_negative_controls",
    "claims",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_entry_contract"},
    "contract_id": {"const": "PKENTRY1"},
    "selected_move_id": {"const": "N6-KENTRY-001"},
    "status_date": {"type": "string"},
    "status": {"const": "candidate_product_image_single_host_non_promoting"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "phase_mapping": {"type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": {"enum": ["N6.4", "N6.5", "N6.6"]}},
    "source_requirement_ids": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"type": "string"}},
    "authorities": {"type": "array", "minItems": 4, "items": {"type": "object"}},
    "product": {
      "type": "object",
      "required": ["package", "binary_name", "published_file_name", "target", "architecture", "format_contract", "handoff_contract", "entry_symbol", "entry_offset", "image_memory_bytes", "canonical_file_bytes", "maximum_linked_file_bytes", "maximum_relocations", "build_id", "manifest_path", "manifest_contract_bindings", "manifest_exactly_once_in_read_only_load"],
      "properties": {
        "package": {"const": "poolekernel"},
        "binary_name": {"const": "PooleKernelLinked"},
        "published_file_name": {"const": "PooleKernel.pkelf"},
        "target": {"const": "x86_64-unknown-none"},
        "architecture": {"const": "x86_64"},
        "format_contract": {"const": "PKELF1"},
        "handoff_contract": {"const": "PBP1"},
        "entry_symbol": {"const": "poole_kernel_entry"},
        "entry_offset": {"const": 32768},
        "image_memory_bytes": {"const": 262144},
        "canonical_file_bytes": {"const": 180224},
        "maximum_linked_file_bytes": {"const": 8388608},
        "maximum_relocations": {"const": 4096},
        "build_id": {"const": "PKBUILD1-CYCLE123-N7-XSTATE-EXCEPTION-001"},
        "manifest_path": {"const": "native/kernel/manifest.pkm"},
        "manifest_contract_bindings": {"type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": {"enum": ["PKENTRY1", "PKELF1", "PBP1"]}},
        "manifest_exactly_once_in_read_only_load": {"const": true}
      }
    },
    "build_profile": {"type": "object"},
    "transfer": {"type": "object"},
    "mapping_preconditions": {"type": "object"},
    "intake": {"type": "object"},
    "early_diagnostics": {"type": "object"},
    "panic_profile": {"type": "object"},
    "required_negative_controls": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"type": "string"}},
    "claims": {"type": "object"},
    "claim_boundary": {"type": "array", "minItems": 7, "items": {"type": "string"}}
  }
}
