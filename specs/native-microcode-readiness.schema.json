{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-microcode-readiness.schema.json",
  "title": "PooleOS PMCU1 qualification readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n5_exit_gate_satisfied",
    "phase_status",
    "bindings",
    "validator_qualification",
    "golden_vectors",
    "negative_controls",
    "parser_differential",
    "selection_differential",
    "post_apply_differential",
    "activation_qualification",
    "claims",
    "summary",
    "open_items",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_microcode_readiness"},
    "status_date": {"const": "2026-07-18"},
    "status": {"const": "pass"},
    "contract_id": {"const": "PMCU1"},
    "selected_move_id": {"const": "N5-MICROCODE-SEMANTICS-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n5_exit_gate_satisfied": {"const": false},
    "phase_status": {"type": "object"},
    "bindings": {"type": "object"},
    "validator_qualification": {"type": "object"},
    "golden_vectors": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "object"}},
    "negative_controls": {"type": "array", "minItems": 170, "items": {"type": "object"}},
    "parser_differential": {"type": "object"},
    "selection_differential": {"type": "object"},
    "post_apply_differential": {"type": "object"},
    "activation_qualification": {"type": "object"},
    "claims": {"type": "object"},
    "summary": {"type": "object"},
    "open_items": {"type": "array", "minItems": 14, "items": {"type": "string"}},
    "claim_boundary": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"type": "string"}}
  }
}
