{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-model-readiness.schema.json",
  "title": "PooleOS bounded native model readiness",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "status_date", "status", "selected_move_id", "production_ready", "production_promotion_allowed", "n4_model_slice_satisfied", "n4_exit_gate_satisfied", "bindings", "toolchain", "domain_coverage", "runs", "negative_controls", "summary", "assumptions", "open_work", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "1.3"},
    "artifact_kind": {"const": "pooleos_native_model_readiness"},
    "status_date": {"const": "2026-07-16"},
    "status": {"const": "bounded_models_pass_counterexamples_detected"},
    "selected_move_id": {"const": "N4-SCHEDULER-MODEL-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n4_model_slice_satisfied": {"const": true},
    "n4_exit_gate_satisfied": {"const": false},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lock", "contract", "implementation_inputs", "model_inputs"],
      "properties": {
        "lock": {"$ref": "#/$defs/binding"},
        "contract": {"$ref": "#/$defs/binding"},
        "implementation_inputs": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"$ref": "#/$defs/binding"}},
        "model_inputs": {"type": "array", "minItems": 25, "maxItems": 25, "items": {"$ref": "#/$defs/binding"}}
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tlc_version", "tlc_jar_sha256", "java_release", "java_runtime_tree_sha256", "workspace_local", "source_built", "second_host_reproduced"],
      "properties": {
        "tlc_version": {"const": "2.19"},
        "tlc_jar_sha256": {"const": "936A262061C914694DFD669A543BE24573C45D5AA0FF20A8B96B23D01E050E88"},
        "java_release": {"const": "jdk-21.0.11+10"},
        "java_runtime_tree_sha256": {"const": "057E582B6FAC90535C1A51A66856C7D7DCCE27B03536FA0FB019A7C7ADA56DC9"},
        "workspace_local": {"const": true},
        "source_built": {"const": false},
        "second_host_reproduced": {"const": false}
      }
    },
    "domain_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_domains", "modeled_domains", "open_domains", "required_count", "modeled_count", "open_count"],
      "properties": {
        "required_domains": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"type": "string"}},
        "modeled_domains": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "string"}},
        "open_domains": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string"}},
        "required_count": {"const": 7},
        "modeled_count": {"const": 6},
        "open_count": {"const": 1}
      }
    },
    "runs": {"type": "array", "minItems": 20, "maxItems": 20, "items": {"$ref": "#/$defs/run"}},
    "negative_controls": {"type": "array", "minItems": 25, "maxItems": 25, "items": {"$ref": "#/$defs/control"}},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_count", "run_case_count", "safe_run_count", "safe_run_pass_count", "hostile_run_count", "hostile_counterexample_count", "repeat_match_count", "negative_control_count", "negative_control_pass_count", "normalized_trace_count", "implementation_trace_cross_check_count", "failed_check_count"],
      "properties": {
        "model_count": {"const": 5},
        "run_case_count": {"const": 20},
        "safe_run_count": {"const": 5},
        "safe_run_pass_count": {"const": 5},
        "hostile_run_count": {"const": 15},
        "hostile_counterexample_count": {"const": 15},
        "repeat_match_count": {"const": 20},
        "negative_control_count": {"const": 25},
        "negative_control_pass_count": {"const": 25},
        "normalized_trace_count": {"const": 15},
        "implementation_trace_cross_check_count": {"const": 0},
        "failed_check_count": {"const": 0}
      }
    },
    "assumptions": {"type": "array", "minItems": 8, "items": {"type": "string"}},
    "open_work": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bounded_state_search_only", "formal_proof_claimed", "fingerprint_collision_free_claimed", "liveness_checked", "implementation_trace_cross_checked", "abi_freeze_authorized", "pooleboot_executed", "poolekernel_executed", "production_promotion_allowed"],
      "properties": {
        "bounded_state_search_only": {"const": true},
        "formal_proof_claimed": {"const": false},
        "fingerprint_collision_free_claimed": {"const": false},
        "liveness_checked": {"const": false},
        "implementation_trace_cross_checked": {"const": false},
        "abi_freeze_authorized": {"const": false},
        "pooleboot_executed": {"const": false},
        "poolekernel_executed": {"const": false},
        "production_promotion_allowed": {"const": false}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "byte_count", "sha256"],
      "properties": {"path": {"type": "string"}, "byte_count": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/sha256"}}
    },
    "trace_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "action", "state_sha256", "state_lines"],
      "properties": {"index": {"type": "integer", "minimum": 1}, "action": {"type": "string"}, "state_sha256": {"$ref": "#/$defs/sha256"}, "state_lines": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "model_id", "case_id", "mode", "status", "expected_exit_code", "observed_exit_code", "expected_invariant_violation", "observed_invariant_violation", "generated_states", "distinct_states", "left_on_queue", "depth", "trace", "trace_sha256", "repeat_exact_match", "raw_output_public", "command_sha256"],
      "properties": {
        "id": {"type": "string"},
        "model_id": {"enum": ["boot_slot_rollback", "capability_revocation", "virtual_memory_ownership", "capability_mediated_ipc", "bounded_scheduler"]},
        "case_id": {"enum": ["safe", "unsafe_rollback", "unsafe_local_revoke", "unsafe_stale_mapping", "unsafe_early_reuse", "unsafe_unauthorized_call", "unsafe_token_reuse", "unsafe_stale_reply", "unsafe_leaky_teardown", "unsafe_lost_cancel_wake", "unsafe_lost_timeout_wake", "unsafe_duplicate_wakeup", "unsafe_no_priority_inheritance", "unsafe_priority_bypass", "unsafe_fairness_bypass", "unsafe_scheduler_teardown_leak"]},
        "mode": {"enum": ["safe", "hostile"]},
        "status": {"const": "pass"},
        "expected_exit_code": {"enum": [0, 12]},
        "observed_exit_code": {"enum": [0, 12]},
        "expected_invariant_violation": {"type": ["string", "null"]},
        "observed_invariant_violation": {"type": ["string", "null"]},
        "generated_states": {"type": "integer", "minimum": 1},
        "distinct_states": {"type": "integer", "minimum": 1},
        "left_on_queue": {"type": "integer", "minimum": 0},
        "depth": {"type": "integer", "minimum": 1},
        "trace": {"type": "array", "items": {"$ref": "#/$defs/trace_step"}},
        "trace_sha256": {"$ref": "#/$defs/sha256"},
        "repeat_exact_match": {"const": true},
        "raw_output_public": {"const": false},
        "command_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "expected", "observed", "status", "evidence_kind"],
      "properties": {"id": {"type": "string"}, "expected": {"const": "reject"}, "observed": {"const": "reject"}, "status": {"const": "pass"}, "evidence_kind": {"type": "string"}}
    }
  }
}
