    },
    {
      "title": "GitHub commit and tag signature verification",
      "url": "https://docs.github.com/en/authentication/managing-commit-signature-verification/about-commit-signature-verification",
      "authority": "official GitHub documentation"
    },
    {
      "title": "GitHub hardware-backed SSH key generation",
      "url": "https://docs.github.com/en/authentication/connecting-to-github-with-ssh/generating-a-new-ssh-key-and-adding-it-to-the-ssh-agent",
      "authority": "official GitHub documentation"
    }
  ],
  "claim_boundary": [
    "The policy and readiness ledger are not signatures and do not imply owner acceptance.",
    "A software governance key is a provisional option only after explicit owner risk acceptance.",
    "The governance key is not a production Secure Boot, package, update, recovery, or ISO release key.",
    "N0 remains open until detached signature, signed tag, and remote publication all verify."
  ]
}
