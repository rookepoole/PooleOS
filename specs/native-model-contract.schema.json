{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-model-contract.schema.json",
  "title": "PooleOS bounded native model contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "status_date", "contract_id", "selected_move_id", "production_ready", "production_promotion_allowed", "engine", "required_domains", "modeled_domains", "models", "assumptions", "trace_cross_check", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "1.2"},
    "artifact_kind": {"const": "pooleos_native_model_contract"},
    "status_date": {"const": "2026-07-16"},
    "contract_id": {"const": "POOLEOS-N4-MODELS-3"},
    "selected_move_id": {"const": "N4-IPC-MODEL-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "version", "execution_mode", "workers", "fingerprint_polynomial", "tool_messages", "repeat_count", "raw_output_public", "normalized_trace_public", "command_template"],
      "properties": {
        "kind": {"const": "TLC explicit-state model checker"},
        "version": {"const": "2.19"},
        "execution_mode": {"const": "breadth_first_complete_reachable_state_search_within_frozen_constants"},
        "workers": {"const": 1},
        "fingerprint_polynomial": {"const": 0},
        "tool_messages": {"const": true},
        "repeat_count": {"const": 2},
        "raw_output_public": {"const": false},
        "normalized_trace_public": {"const": true},
        "command_template": {"type": "array", "minItems": 17, "maxItems": 17, "items": {"type": "string"}}
      }
    },
    "required_domains": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"type": "string"}},
    "modeled_domains": {"type": "array", "minItems": 5, "maxItems": 5, "uniqueItems": true, "items": {"type": "string"}},
    "models": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "module_path", "state_variables", "invariants", "cases"],
        "properties": {
          "id": {"enum": ["boot_slot_rollback", "capability_revocation", "virtual_memory_ownership", "capability_mediated_ipc"]},
          "module_path": {"type": "string"},
          "state_variables": {"type": "array", "minItems": 5, "maxItems": 13, "uniqueItems": true, "items": {"type": "string"}},
          "invariants": {"type": "array", "minItems": 6, "maxItems": 11, "uniqueItems": true, "items": {"type": "string"}},
          "cases": {"type": "array", "minItems": 2, "maxItems": 5, "items": {"$ref": "#/$defs/case"}}
        }
      }
    },
    "assumptions": {"type": "array", "minItems": 7, "items": {"type": "string"}},
    "trace_cross_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_model_count", "completed_model_count", "abi_freeze_authorized"],
      "properties": {
        "status": {"const": "pending_native_implementation_traces"},
        "required_model_count": {"const": 4},
        "completed_model_count": {"const": 0},
        "abi_freeze_authorized": {"const": false}
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bounded_model_checks_claimed", "formal_proof_claimed", "implementation_correctness_claimed", "kernel_execution_claimed", "boot_execution_claimed", "n4_exit_gate_claimed"],
      "properties": {
        "bounded_model_checks_claimed": {"const": true},
        "formal_proof_claimed": {"const": false},
        "implementation_correctness_claimed": {"const": false},
        "kernel_execution_claimed": {"const": false},
        "boot_execution_claimed": {"const": false},
        "n4_exit_gate_claimed": {"const": false}
      }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "config_path", "constant_assignments", "expected_invariant_violation", "expected"],
      "properties": {
        "id": {"enum": ["safe", "unsafe_rollback", "unsafe_local_revoke", "unsafe_stale_mapping", "unsafe_early_reuse", "unsafe_unauthorized_call", "unsafe_token_reuse", "unsafe_stale_reply", "unsafe_leaky_teardown"]},
        "role": {"enum": ["safe", "hostile"]},
        "config_path": {"type": "string"},
        "constant_assignments": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 4,
          "additionalProperties": {"enum": ["TRUE", "FALSE"]}
        },
        "expected_invariant_violation": {"type": ["string", "null"]},
        "expected": {"$ref": "#/$defs/outcome"}
      },
      "allOf": [
        {
          "if": {"properties": {"role": {"const": "safe"}}},
          "then": {
            "properties": {
              "expected_invariant_violation": {"type": "null"},
              "expected": {"properties": {"exit_code": {"const": 0}, "trace_length": {"const": 0}, "trace_actions": {"maxItems": 0}}}
            }
          }
        },
        {
          "if": {"properties": {"role": {"const": "hostile"}}},
          "then": {
            "properties": {
              "expected_invariant_violation": {"type": "string", "minLength": 1},
              "expected": {"properties": {"exit_code": {"const": 12}, "trace_length": {"minimum": 1}, "trace_actions": {"minItems": 1}}}
            }
          }
        }
      ]
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "generated_states", "distinct_states", "left_on_queue", "depth", "trace_length", "trace_actions", "trace_sha256"],
      "properties": {
        "exit_code": {"enum": [0, 12]},
        "generated_states": {"type": "integer", "minimum": 1},
        "distinct_states": {"type": "integer", "minimum": 1},
        "left_on_queue": {"type": "integer", "minimum": 0},
        "depth": {"type": "integer", "minimum": 1},
        "trace_length": {"type": "integer", "minimum": 0, "maximum": 6},
        "trace_actions": {"type": "array", "maxItems": 6, "items": {"type": "string"}},
        "trace_sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"}
      }
    }
  }
}
