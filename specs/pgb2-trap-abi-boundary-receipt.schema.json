{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pgb2-trap-abi-boundary-receipt.schema.json",
  "title": "PooleOS PGB2 Trap ABI Boundary Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "boundary_version",
    "abi_boundary",
    "evidence_sources",
    "claim_boundaries",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.pgb2_trap_abi_boundary_receipt"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft_verified",
        "verification_failed",
        "invalid"
      ]
    },
    "boundary_version": {
      "type": "string"
    },
    "abi_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "encoding_version",
        "execution_version",
        "byte_format_classification",
        "abi_frozen",
        "kernel_abi_promotion_allowed",
        "kernel_enforcement_claimed",
        "security_boundary_claimed"
      ],
      "properties": {
        "encoding_version": {
          "type": "string"
        },
        "execution_version": {
          "type": "string"
        },
        "byte_format_classification": {
          "type": "string"
        },
        "abi_frozen": {
          "type": "boolean"
        },
        "kernel_abi_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        },
        "security_boundary_claimed": {
          "type": "boolean"
        }
      }
    },
    "evidence_sources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trap_encoding",
        "trap_execution",
        "bundle",
        "boot_trap_bundle_manifest",
        "qemu_shared_folder_contract"
      ],
      "properties": {
        "trap_encoding": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_path",
            "exists",
            "sha256",
            "artifact_kind",
            "status",
            "failed_check_count",
            "encoding_version",
            "program_sha256",
            "instruction_count",
            "byte_length",
            "matrix_bound",
            "fuzz_bound",
            "core_ir_binding_mode",
            "parser_to_kernel_promotion_allowed",
            "kernel_enforcement_claimed"
          ],
          "properties": {
            "artifact_path": {
              "type": "string"
            },
            "exists": {
              "type": "boolean"
            },
            "sha256": {
              "type": "string"
            },
            "artifact_kind": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "failed_check_count": {
              "type": "integer"
            },
            "encoding_version": {
              "type": "string"
            },
            "program_sha256": {
              "type": "string"
            },
            "instruction_count": {
              "type": "integer"
            },
            "byte_length": {
              "type": "integer"
            },
            "matrix_bound": {
              "type": "boolean"
            },
            "fuzz_bound": {
              "type": "boolean"
            },
            "core_ir_binding_mode": {
              "type": "string"
            },
            "parser_to_kernel_promotion_allowed": {
              "type": "boolean"
            },
            "kernel_enforcement_claimed": {
              "type": "boolean"
            }
          }
        },
        "trap_execution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "artifact_path",
            "exists",
            "sha256",
            "artifact_kind",
            "status",
            "failed_check_count",
            "execution_version",
            "encoding_version",
            "encoded_instruction_count",
            "executed_instruction_count",
            "byte_length",
            "program_sha256",
            "decode_error_count",
            "outcome_mismatch_count",
            "security_boundary_claimed",
            "all_bytes_consumed",
            "core_ir_binding_mode",
            "parser_to_kernel_promotion_allowed",
            "kernel_enforcement_claimed"
          ],
