{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-pooleboot-readiness.schema.json",
  "title": "PooleOS bounded PooleBoot readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n5_exit_gate_satisfied",
    "phase_status",
    "bindings",
    "build",
    "media",
    "execution",
    "negative_controls",
    "claims",
    "summary",
    "open_items",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_pooleboot_readiness"},
    "status_date": {"const": "2026-07-16"},
    "status": {"const": "pass_single_host_two_run_unsigned_live_load_then_release_non_promoting"},
    "contract_id": {"const": "POOLEOS-N5-POOLEBOOT-2"},
    "selected_move_id": {"const": "N5-KLOAD-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n5_exit_gate_satisfied": {"const": false},
    "phase_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["N5", "N5.1", "N5.2", "N5.3", "N5.4", "N5.5", "N5.7"],
      "properties": {
        "N5": {"const": "partial"},
        "N5.1": {"const": "partial"},
        "N5.2": {"const": "partial"},
        "N5.3": {"const": "partial"},
        "N5.4": {"const": "partial"},
        "N5.5": {"const": "partial"},
        "N5.7": {"const": "partial"}
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "toolchain_lock", "toolchain_qualification", "tier0_lock", "tier0_profile", "tier0_readiness", "kernel_entry_readiness", "kernel_load_contract", "kernel_load_readiness", "implementation_inputs"],
      "properties": {
        "contract": {"$ref": "#/$defs/binding"},
        "toolchain_lock": {"$ref": "#/$defs/binding"},
        "toolchain_qualification": {"$ref": "#/$defs/binding"},
        "tier0_lock": {"$ref": "#/$defs/binding"},
        "tier0_profile": {"$ref": "#/$defs/binding"},
        "tier0_readiness": {"$ref": "#/$defs/binding"},
        "kernel_entry_readiness": {"$ref": "#/$defs/binding"},
        "kernel_load_contract": {"$ref": "#/$defs/binding"},
        "kernel_load_readiness": {"$ref": "#/$defs/binding"},
        "implementation_inputs": {"type": "array", "minItems": 32, "maxItems": 32, "items": {"$ref": "#/$defs/binding"}}
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_contract_test_count", "host_contract_test_pass_count", "clean_build_count", "exact_clean_build_match", "sha256", "byte_count", "inspection", "host_leakage_marker_count", "host_leakage_hit_count"],
      "properties": {
        "host_contract_test_count": {"minimum": 8},
        "host_contract_test_pass_count": {"minimum": 8},
        "clean_build_count": {"const": 2},
        "exact_clean_build_match": {"const": true},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_count": {"type": "integer", "minimum": 1, "maximum": 262144},
        "inspection": {"type": "object", "required": ["format", "machine", "subsystem", "timestamp", "entry_nonzero", "imports_present", "debug_directory_present"]},
        "host_leakage_marker_count": {"type": "integer", "minimum": 1},
        "host_leakage_hit_count": {"const": 0}
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clean_generation_count", "exact_clean_generation_match", "ordinary_workspace_file_only", "physical_media_write_performed", "inspection"],
      "properties": {
        "clean_generation_count": {"const": 2},
        "exact_clean_generation_match": {"const": true},
        "ordinary_workspace_file_only": {"const": true},
        "physical_media_write_performed": {"const": false},
        "inspection": {
          "type": "object",
          "required": ["image", "gpt", "esp", "fat32", "files", "embedded_efi", "config", "kernel"],
          "properties": {
            "image": {"type": "object", "required": ["sha256", "byte_count", "sector_bytes", "sector_count", "protective_mbr_valid"]},
            "gpt": {"type": "object", "required": ["disk_guid", "primary_header_crc32", "backup_header_crc32", "partition_entries_crc32", "primary_backup_entries_exact_match"]},
            "esp": {"type": "object", "required": ["type_guid", "unique_guid", "start_lba", "end_lba", "sector_count", "label"]},
            "fat32": {"type": "object", "required": ["volume_label", "volume_id", "fat_count", "fat_sector_count", "cluster_count", "fat_copies_exact_match", "boot_sector_backup_exact_match", "fsinfo_backup_exact_match"]},
            "files": {"type": "array", "minItems": 3, "maxItems": 3},
            "embedded_efi": {"type": "object"}
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_environment_count", "run_count", "profile_id", "machine", "qemu_sha256", "firmware_code_sha256", "vars_template_sha256", "normalized_command", "normalized_command_sha256", "exact_marker_match", "exact_screenshot_match", "local_paths_recorded", "runs"],
      "properties": {
        "host_environment_count": {"const": 1},
        "run_count": {"const": 2},
        "profile_id": {"const": "bootstrap-debug"},
        "machine": {"const": "pc-q35-11.0"},
        "qemu_sha256": {"$ref": "#/$defs/sha256"},
        "firmware_code_sha256": {"$ref": "#/$defs/sha256"},
        "vars_template_sha256": {"$ref": "#/$defs/sha256"},
        "normalized_command": {"type": "array", "minItems": 50, "items": {"type": "string"}},
        "normalized_command_sha256": {"$ref": "#/$defs/sha256"},
        "exact_marker_match": {"const": true},
        "exact_screenshot_match": {"const": true},
        "local_paths_recorded": {"const": false},
        "runs": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"$ref": "#/$defs/run"}}
      }
    },
    "negative_controls": {"type": "array", "minItems": 30, "maxItems": 30, "items": {"$ref": "#/$defs/control"}},
    "claims": {
      "type": "object",
      "additionalProperties": false,
      "required": ["one_host_pe32_reproducible", "deterministic_gpt_esp_observed", "pooleboot_guest_entry_observed", "gop_frame_observed", "bounded_memory_map_observed", "efi_success_return_path_marker_observed", "complete_pooleboot_loader", "poolekernel_loaded", "poolekernel_executed", "exit_boot_services_called", "secure_boot_enforced", "measured_boot_performed", "owner_signature_present", "target_firmware_tested", "physical_media_tested", "n5_exit_gate_satisfied", "production_boot_evidence", "production_ready"],
      "properties": {
        "one_host_pe32_reproducible": {"const": true},
        "deterministic_gpt_esp_observed": {"const": true},
        "pooleboot_guest_entry_observed": {"const": true},
        "gop_frame_observed": {"const": true},
        "bounded_memory_map_observed": {"const": true},
        "efi_success_return_path_marker_observed": {"const": true},
        "complete_pooleboot_loader": {"const": false},
        "poolekernel_loaded": {"const": true},
        "poolekernel_executed": {"const": false},
        "exit_boot_services_called": {"const": false},
        "secure_boot_enforced": {"const": false},
        "measured_boot_performed": {"const": false},
        "owner_signature_present": {"const": false},
        "target_firmware_tested": {"const": false},
        "physical_media_tested": {"const": false},
        "n5_exit_gate_satisfied": {"const": false},
        "production_boot_evidence": {"const": false},
        "production_ready": {"const": false}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host_contract_tests_passed", "host_contract_tests_total", "clean_builds_exact", "clean_media_generations_exact", "guest_runs_passed", "guest_runs_total", "ordered_marker_count", "serial_debugcon_match_count", "gop_frame_match_count", "negative_controls_passed", "negative_controls_total", "production_claim_count"],
      "properties": {
        "host_contract_tests_passed": {"type": "integer", "minimum": 8},
        "host_contract_tests_total": {"type": "integer", "minimum": 8},
        "clean_builds_exact": {"const": 2},
        "clean_media_generations_exact": {"const": 2},
        "guest_runs_passed": {"const": 2},
        "guest_runs_total": {"const": 2},
        "ordered_marker_count": {"const": 17},
        "serial_debugcon_match_count": {"const": 2},
        "gop_frame_match_count": {"const": 2},
        "negative_controls_passed": {"const": 30},
        "negative_controls_total": {"const": 30},
        "production_claim_count": {"const": 0}
      }
    },
    "open_items": {"type": "array", "minItems": 8, "items": {"type": "string"}},
    "claim_boundary": {"type": "array", "minItems": 10, "items": {"type": "string"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_count"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "byte_count": {"type": "integer", "minimum": 1}
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_id", "fresh_vars_copy", "media_read_only", "guest_network", "host_acceleration", "qmp_loopback_only", "qmp_greeting", "timestamped_qmp_events_excluded_from_equality", "qmp_quit_requested", "qemu_exit_code", "markers", "marker_sha256", "serial_debugcon_exact_match", "marker_summary", "screenshot", "stderr_sha256", "stderr_byte_count", "local_paths_recorded"],
      "properties": {
        "fresh_vars_copy": {"const": true},
        "media_read_only": {"const": true},
        "guest_network": {"const": false},
        "host_acceleration": {"const": false},
        "qmp_loopback_only": {"const": true},
        "timestamped_qmp_events_excluded_from_equality": {"const": true},
        "qmp_quit_requested": {"const": true},
        "qemu_exit_code": {"const": 0},
        "markers": {"type": "array", "minItems": 17, "maxItems": 17, "items": {"type": "string"}},
        "marker_sha256": {"$ref": "#/$defs/sha256"},
        "serial_debugcon_exact_match": {"const": true},
        "screenshot": {"type": "object", "required": ["sha256", "byte_count", "width", "height", "pixel_count", "sampled_unique_color_count", "bright_cyan_pixel_count", "dark_pixel_count", "nonblank", "poole_identity_palette_observed"]},
        "stderr_sha256": {"$ref": "#/$defs/sha256"},
        "stderr_byte_count": {"const": 0},
        "local_paths_recorded": {"const": false}
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "expected", "observed", "status"],
      "properties": {
        "id": {"type": "string"},
        "expected": {"const": "reject"},
        "observed": {"const": "reject"},
        "status": {"const": "pass"}
      }
    }
  }
}
