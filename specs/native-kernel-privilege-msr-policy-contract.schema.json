{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.example/specs/native-kernel-privilege-msr-policy-contract.schema.json",
  "title": "PooleOS PKMSR1 contract",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "selected_move_id",
    "status_date",
    "status",
    "production_ready",
    "production_promotion_allowed",
    "phase_mapping",
    "development_profile",
    "system_linkage_policy",
    "per_cpu_base_policy",
    "machine_check_policy",
    "performance_monitoring_policy",
    "authority_gate",
    "qualification",
    "source_register",
    "required_negative_controls",
    "claims",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_privilege_msr_policy_contract"},
    "contract_id": {"const": "PKMSR1"},
    "selected_move_id": {"const": "N7-PRIVILEGE-MSR-POLICY-001"},
    "status_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "status": {"const": "frozen_bounded_bsp_read_only_privileged_msr_policy_non_promoting"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "phase_mapping": {"const": ["N7.3"]},
    "development_profile": {"type": "object"},
    "system_linkage_policy": {"type": "object"},
    "per_cpu_base_policy": {"type": "object"},
    "machine_check_policy": {"type": "object"},
    "performance_monitoring_policy": {"type": "object"},
    "authority_gate": {"type": "object"},
    "qualification": {"type": "object"},
    "source_register": {"type": "array", "minItems": 2},
    "required_negative_controls": {"type": "array", "minItems": 47, "maxItems": 47, "uniqueItems": true},
    "claims": {"type": "object"},
    "non_claims": {"type": "array", "minItems": 7, "items": {"type": "string"}}
  }
}
