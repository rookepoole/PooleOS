{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/schemas/native-kernel-errata-policy-readiness.schema.json",
  "title": "PooleOS PKERR1 readiness receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n7_exit_gate_satisfied",
    "phase_status",
    "inputs",
    "build_qualification",
    "source_audit",
    "windows_registry_observation",
    "current_policy_decision",
    "synthetic_policy_decision",
    "cross_language_vectors",
    "negative_controls",
    "claims",
    "summary",
    "open_items",
    "non_claims"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_errata_policy_readiness"},
    "status_date": {"type": "string", "format": "date"},
    "status": {"const": "pass_policy_denies_current_target"},
    "contract_id": {"const": "PKERR1"},
    "selected_move_id": {"const": "N7-ERRATA-POLICY-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n7_exit_gate_satisfied": {"const": false},
    "phase_status": {"type": "object"},
    "inputs": {"type": "object"},
    "build_qualification": {"type": "object"},
    "source_audit": {"type": "object"},
    "windows_registry_observation": {"type": "object"},
    "current_policy_decision": {"type": "object"},
    "synthetic_policy_decision": {"type": "object"},
    "cross_language_vectors": {"type": "object"},
    "negative_controls": {"type": "array", "minItems": 24, "maxItems": 24, "items": {"type": "object"}},
    "claims": {"type": "object"},
    "summary": {"type": "object"},
    "open_items": {"type": "array", "minItems": 8, "items": {"type": "string"}},
    "non_claims": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "string"}}
  }
}
