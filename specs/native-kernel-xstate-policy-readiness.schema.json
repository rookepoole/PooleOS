{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PooleOS PKXSTATE1 readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status_date",
    "status",
    "contract_id",
    "selected_move_id",
    "production_ready",
    "production_promotion_allowed",
    "n7_exit_gate_satisfied",
    "phase_status",
    "inputs",
    "build",
    "media",
    "execution",
    "negative_controls",
    "claims",
    "non_claims",
    "summary",
    "open_items"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_xstate_policy_readiness"},
    "status_date": {"type": "string", "format": "date"},
    "status": {"type": "string", "minLength": 1},
    "contract_id": {"const": "PKXSTATE1"},
    "selected_move_id": {"const": "N7-XSTATE-POLICY-001"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "n7_exit_gate_satisfied": {"const": false},
    "phase_status": {"type": "object"},
    "inputs": {"type": "object"},
    "build": {"type": "object"},
    "media": {"type": "object"},
    "execution": {"type": "object"},
    "negative_controls": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "claims": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "non_claims": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "summary": {"type": "object"},
    "open_items": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  }
}
