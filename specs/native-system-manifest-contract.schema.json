{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-system-manifest-contract.schema.json",
  "title": "PooleOS PSM1 system manifest contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact_kind", "contract_id", "status", "selected_move_id", "production_ready", "encoding", "grammar", "limits", "artifact_types", "path_policy", "kernel_binding", "version_policy", "digest_provider_contract", "phase_mapping", "required_golden_vector_count", "required_negative_controls", "required_differential_cases", "claims", "claim_boundary"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_system_manifest_contract"},
    "contract_id": {"const": "PSM1"},
    "status": {"const": "candidate_pre_abi_pre_signature_non_promoting"},
    "selected_move_id": {"const": "N5-MANIFEST-001"},
    "production_ready": {"const": false},
    "encoding": {"type": "object"},
    "grammar": {"type": "object"},
    "limits": {"type": "object"},
    "artifact_types": {"const": ["kernel", "initial_system", "recovery", "symbols", "microcode", "firmware", "policy", "pooleglyph"]},
    "path_policy": {"type": "object"},
    "kernel_binding": {"type": "object"},
    "version_policy": {"type": "object"},
    "digest_provider_contract": {"const": "PBDIGEST1"},
    "phase_mapping": {"const": ["N5.1", "N5.4", "N5.5"]},
    "required_golden_vector_count": {"const": 3},
    "required_negative_controls": {"type": "array", "minItems": 64, "maxItems": 64, "items": {"type": "string"}},
    "required_differential_cases": {"const": 16384},
    "claims": {"type": "object"},
    "claim_boundary": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"type": "string"}}
  }
}
