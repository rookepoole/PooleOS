{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-kernel-load-contract.schema.json",
  "title": "PooleOS PKLOAD5 contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "selected_move_id",
    "status_date",
    "status",
    "production_ready",
    "production_promotion_allowed",
    "phase_mapping",
    "firmware_protocols",
    "media",
    "selection",
    "file_intake",
    "kernel_load",
    "retained_kernel_mapping",
    "final_exit_pbp1",
    "cleanup",
    "execution",
    "required_marker_count",
    "required_markers",
    "required_negative_controls",
    "claims",
    "claim_boundary",
    "official_references"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_kernel_load_contract"},
    "contract_id": {"const": "PKLOAD5"},
    "selected_move_id": {"const": "N5-HANDOFF-001"},
    "status_date": {"const": "2026-07-17"},
    "status": {"const": "bounded_live_pkmap2_retention_exit_boot_services_then_stop_non_promoting"},
    "production_ready": {"const": false},
    "production_promotion_allowed": {"const": false},
    "phase_mapping": {"const": ["N5.1", "N5.4", "N5.5", "N5.8"]},
    "media": {
      "type": "object",
      "required": ["boot_path", "config_path", "manifest_path", "kernel_path", "config_maximum_bytes", "manifest_maximum_bytes", "kernel_file_maximum_bytes", "physical_media_write_allowed"],
      "properties": {
        "boot_path": {"const": "EFI/BOOT/BOOTX64.EFI"},
        "config_path": {"const": "EFI/POOLEOS/BOOT.CFG"},
        "manifest_path": {"const": "EFI/POOLEOS/SYSTEM_A.PBM"},
        "kernel_path": {"const": "EFI/POOLEOS/KERNEL.ELF"},
        "config_maximum_bytes": {"const": 16384},
        "manifest_maximum_bytes": {"const": 65536},
        "kernel_file_maximum_bytes": {"const": 1048576},
        "physical_media_write_allowed": {"const": false}
      }
    },
    "kernel_load": {
      "type": "object",
      "required": ["format_contract", "page_bytes", "mapping_plan_permissions", "writable_executable_mapping_allowed", "temporary_page_tables_activated", "page_tables_retained", "entry_called", "kernel_pages_retained_through_pbp1", "kernel_pages_retained_after_exit"],
      "properties": {
        "format_contract": {"const": "PKELF1"},
        "page_bytes": {"const": 4096},
        "mapping_plan_permissions": {"const": ["r", "rx", "r", "rw"]},
        "writable_executable_mapping_allowed": {"const": false},
        "temporary_page_tables_activated": {"const": true},
        "page_tables_retained": {"const": true},
        "entry_called": {"const": false},
        "kernel_pages_retained_through_pbp1": {"const": true},
        "kernel_pages_retained_after_exit": {"const": true}
      }
    },
    "retained_kernel_mapping": {
      "type": "object",
      "required": ["contract", "private_table_page_count", "guarded_stack_page_count", "guard_page_count", "read_only_handoff_page_count", "candidate_tables_retained_through_exit", "kernel_entry_called"],
      "properties": {
        "contract": {"const": "PKMAP2"},
        "private_table_page_count": {"const": 4},
        "guarded_stack_page_count": {"const": 8},
        "guard_page_count": {"const": 2},
        "read_only_handoff_page_count": {"const": 256},
        "candidate_tables_retained_through_exit": {"const": true},
        "kernel_entry_called": {"const": false}
      }
    },
    "final_exit_pbp1": {
      "type": "object",
      "required": ["producer_contract", "wire_contract", "raw_uefi_descriptor_stride_honored", "boot_services_exited", "kernel_entry_profile_must_reject", "retained_range_loader_coverage_required", "container_retained_after_exit", "transferable"],
      "properties": {
        "producer_contract": {"const": "PBLIVE2"},
        "wire_contract": {"const": "PBP1"},
        "raw_uefi_descriptor_stride_honored": {"const": true},
        "boot_services_exited": {"const": true},
        "kernel_entry_profile_must_reject": {"const": true},
        "retained_range_loader_coverage_required": {"const": true},
        "container_retained_after_exit": {"const": true},
        "transferable": {"const": false}
      }
    },
    "required_marker_count": {"const": 22},
    "required_markers": {"type": "array", "minItems": 22, "maxItems": 22, "items": {"type": "string"}},
    "required_negative_controls": {"type": "array", "minItems": 95, "maxItems": 95, "uniqueItems": true, "items": {"type": "string"}},
    "claims": {"type": "object", "additionalProperties": {"type": "boolean"}, "minProperties": 49, "maxProperties": 49},
    "claim_boundary": {"type": "array", "minItems": 10, "items": {"type": "string"}},
    "official_references": {"type": "array", "minItems": 3, "items": {"type": "string", "format": "uri"}}
  }
}
