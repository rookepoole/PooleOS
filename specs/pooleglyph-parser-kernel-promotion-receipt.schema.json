{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/pooleglyph-parser-kernel-promotion-receipt.schema.json",
  "title": "PooleGlyph Parser Kernel Promotion Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "status",
    "source_executable_audit",
    "promotion_decision",
    "checks",
    "summary",
    "limitations",
    "next_steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "artifact_kind": {
      "const": "pooleos.pooleglyph_parser_kernel_promotion_receipt"
    },
    "status": {
      "type": "string",
      "enum": [
        "blocked_until_phase66",
        "parser_to_kernel_ready",
        "fail"
      ]
    },
    "source_executable_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_path",
        "exists",
        "artifact_kind",
        "status",
        "source_boundary_receipt",
        "phase66_audit_present",
        "parser_to_kernel_promotion_allowed",
        "kernel_handoff_allowed",
        "kernel_enforcement_claimed",
        "failed_check_count"
      ],
      "properties": {
        "artifact_path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "artifact_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "source_boundary_receipt": {
          "type": "string"
        },
        "phase66_audit_present": {
          "type": "boolean"
        },
        "parser_to_kernel_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_handoff_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        },
        "failed_check_count": {
          "type": "integer"
        }
      }
    },
    "promotion_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parser_to_kernel_promotion_allowed",
        "kernel_handoff_allowed",
        "kernel_enforcement_claimed",
        "decision",
        "reason"
      ],
      "properties": {
        "parser_to_kernel_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_handoff_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        },
        "decision": {
          "type": "string",
          "enum": [
            "blocked_until_phase66_promotion",
            "allow_parser_to_kernel_handoff"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failed_check_count",
        "phase66_audit_present",
        "parser_to_kernel_promotion_allowed",
        "kernel_handoff_allowed",
        "kernel_enforcement_claimed",
        "executable_candidate_count",
        "metadata_zero_count",
        "unexpected_invalid_count"
      ],
      "properties": {
        "failed_check_count": {
          "type": "integer"
        },
        "phase66_audit_present": {
          "type": "boolean"
        },
        "parser_to_kernel_promotion_allowed": {
          "type": "boolean"
        },
        "kernel_handoff_allowed": {
          "type": "boolean"
        },
        "kernel_enforcement_claimed": {
          "type": "boolean"
        },
        "executable_candidate_count": {
          "type": "integer"
        },
        "metadata_zero_count": {
          "type": "integer"
        },
        "unexpected_invalid_count": {
          "type": "integer"
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "ok",
        "detail"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
