{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pooleos.local/specs/native-microcode-contract.schema.json",
  "title": "PooleOS PMCU1 microcode contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_kind",
    "contract_id",
    "status",
    "production_ready",
    "target",
    "layout",
    "vendor_container_policy",
    "selection_policy",
    "apply_sequence",
    "activation_preconditions",
    "research_basis",
    "claims",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "artifact_kind": {"const": "pooleos_native_microcode_contract"},
    "contract_id": {"const": "PMCU1"},
    "status": {"const": "candidate_pre_abi_non_promoting"},
    "production_ready": {"const": false},
    "target": {"type": "object"},
    "layout": {"type": "object"},
    "vendor_container_policy": {"type": "object"},
    "selection_policy": {"type": "object"},
    "apply_sequence": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "string"}},
    "activation_preconditions": {"type": "array", "minItems": 10, "maxItems": 10, "items": {"type": "string"}},
    "research_basis": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"type": "string", "format": "uri"}},
    "claims": {
      "type": "object",
      "required": [
        "format_frozen",
        "python_oracle_implemented",
        "no_std_parser_implemented",
        "bounded_selection_implemented",
        "post_apply_verification_model_implemented",
        "vendor_container_parser_implemented",
        "vendor_payload_included",
        "privileged_revision_observed",
        "microcode_applied",
        "pooleboot_enforcement",
        "poolekernel_enforcement",
        "production_ready"
      ]
    },
    "claim_boundary": {"type": "array", "minItems": 11, "maxItems": 11, "items": {"type": "string"}}
  }
}
